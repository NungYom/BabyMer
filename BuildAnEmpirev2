-------------------------------------------------------
-- [ ฟังก์ชันค้นหาโฟลเดอร์ Economy แบบ Dynamic ]
-------------------------------------------------------
local function getMyEconomy()
    -- ค้นหา Buildings > [ชื่อผู้เล่น]Buildings > Economy
    local myBuildingFolder = workspace:FindFirstChild("Buildings") and workspace.Buildings:FindFirstChild(Player.Name .. "Buildings")
    if myBuildingFolder then
        return myBuildingFolder:FindFirstChild("Economy")
    end
    return nil
end

-------------------------------------------------------
-- [1] Auto Obby (TP ไป ObbyWin และกลับมาล็อคตำแหน่ง 2 วิ)
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Obby (150s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoObby = Value
      if Value then
         task.spawn(function()
            while _G.AutoObby do
                local char = Player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local obbyWin = workspace:FindFirstChild("Obby") and workspace.Obby:FindFirstChild("ObbyWin") --
                
                if root and obbyWin then
                    local oldPos = root.CFrame 
                    root.CFrame = obbyWin.CFrame
                    task.wait(1)
                    
                    -- ล็อคตำแหน่งขากลับ 2 วินาที
                    local startTime = tick()
                    while tick() - startTime < 2 do
                        root.CFrame = oldPos 
                        task.wait() 
                    end
                end
                for i = 1, 150 do if not _G.AutoObby then break end task.wait(1) end
            end
         end)
      end
   end,
})

-------------------------------------------------------
-- [2] Auto Collect (อัปเดตค่า Real-time จาก ObjectText)
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Collect Economy (Stable)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
         task.spawn(function()
            while _G.AutoCollect do
                local economy = getMyEconomy()
                if economy then
                    for _, building in pairs(economy:GetChildren()) do
                        if not _G.AutoCollect then break end
                        local prompt = building:FindFirstChild("CollectPrompt", true)
                        -- แกะค่าจาก ObjectText เช่น "328 Carrot"
                        if prompt and prompt.ObjectText ~= "" then
                            local amountStr, itemName = prompt.ObjectText:match("(%d+)%s+(.+)")
                            if amountStr and tonumber(amountStr) > 0 then
                                pcall(function()
                                    NetworkRemote:FireServer(buffer.fromstring("\018\001"), {{ building.Name, itemName, tonumber(amountStr) }})
                                end)
                                task.wait(0.2) -- พักหายใจ
                            end
                        end
                    end
                end
                task.wait(2) -- พักรอบใหญ่
            end
         end)
      end
   end,
})

