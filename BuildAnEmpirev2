BuyTab:CreateDropdown({
   Name = "เลือกของที่จะซื้อ",
   Options = {"Small Cube", "Apartments", "Fortress", "Copper Mine", "Small Lake", "Library", "Gold Mine", "Diamond Mine", "Workshop", "Royal Castle", "War Castle", "Giant Cave", "Training Camp", "Mines Booster", "Clock", "Time Machine", "Unit Hut"},
   MultipleOptions = true,
   Callback = function(Opts) _G.SelectedBuildings = Opts end,
})

BuyTab:CreateToggle({
   Name = "เปิด Auto Buy (5s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuy = Value
      if Value then
         task.spawn(function()
            while _G.AutoBuy do
                for _, name in pairs(_G.SelectedBuildings) do
                    if not _G.AutoBuy then break end
                    local cat = BuildingMap[name]
                    if cat then 
                        pcall(function() NetworkRemote:FireServer(buffer.fromstring("\020\001"), {{ name, cat }}) end)
                        -- เพิ่ม wait ใน loop ซ้อน ป้องกันการส่ง Data ถี่เกินไป
                        task.wait(0.5) 
                    end
                end
                task.wait(5)
            end
         end)
      end
   end,
})
