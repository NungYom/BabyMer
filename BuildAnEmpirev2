-------------------------------------------------------
-- [3] Auto Obby
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Obby",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoObby = Value
      if Value then
         task.spawn(function()
            while _G.AutoObby do
                local char = Player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local obbyWin = workspace:FindFirstChild("Obby") and workspace.Obby:FindFirstChild("ObbyWin")
                
                if root and obbyWin then
                    local oldPos = root.CFrame
                    root.CFrame = obbyWin.CFrame
                    task.wait(1)
                    
                    local startTime = tick()
                    while tick() - startTime < 2 do
                        root.CFrame = oldPos
                        task.wait()
                    end
                end
                
                -- รอ 150 วินาที เพื่อป้องกันการโดนเตะ
                for i = 1, 150 do
                    if not _G.AutoObby then break end
                    task.wait(1)
                end
            end
         end)
      end
   end,
})

-------------------------------------------------------
-- [4] Auto Collect Economy (Optimized: 10s Delay)
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Collect Economy (10s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
         task.spawn(function()
            while _G.AutoCollect do
                pcall(function()
                    local buildings = workspace.Buildings:FindFirstChild(Player.Name .. "Buildings")
                    local economy = buildings and buildings:FindFirstChild("Economy")
                    
                    if economy then
                        for _, b in pairs(economy:GetChildren()) do
                            if not _G.AutoCollect then break end
                            local prompt = b:FindFirstChild("CollectPrompt", true)
                            if prompt and prompt.ObjectText ~= "" then
                                local amnt, item = prompt.ObjectText:match("(%d+)%s+(.+)")
                                if amnt and tonumber(amnt) > 0 then
                                    NetworkRemote:FireServer(buffer.fromstring("\018\001"), {{ b.Name, item, tonumber(amnt) }})
                                    -- เพิ่ม wait เล็กน้อยใน loop ซ้อนเพื่อไม่ให้ CPU Spike
                                    task.wait(0.2) 
                                end
                            end
                        end
                    end
                end)
                -- รอ 10 วินาทีตามที่นายต้องการ เพื่อลดภาระเครื่อง
                task.wait(10)
            end
         end)
      end
   end,
})

