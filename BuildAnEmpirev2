-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = game:GetService("Players").LocalPlayer
local NetworkRemote = ReplicatedStorage:WaitForChild("_GAME"):WaitForChild("MODULES"):WaitForChild("NetworkUtility"):WaitForChild("ByteNetMax"):WaitForChild("system"):WaitForChild("ByteNetReliable")
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

-- ตัวแปรควบคุม
_G.AutoObby = false
_G.AutoCollect = false
_G.AutoSell = false
_G.AutoBuy = false
_G.CPUSaver = false
_G.SelectedBuildings = {}

-- ตารางคู่ ชื่อ-หมวดหมู่
local BuildingMap = {
    ["Small Cube"] = "Housing", ["Apartments"] = "Housing",
    ["Copper Mine"] = "Economy", ["Small Lake"] = "Economy", ["Library"] = "Economy", ["Gold Mine"] = "Economy", ["Diamond Mine"] = "Economy",
    ["Workshop"] = "Utility", ["Royal Castle"] = "Utility", ["War Castle"] = "Utility", ["Giant Cave"] = "Utility", ["Training Camp"] = "Utility", ["Mines Booster"] = "Utility", ["Clock"] = "Utility", ["Time Machine"] = "Utility", ["Unit Hut"] = "Utility"
}

local MainTab = Window:CreateTab("ฟาร์มหลัก", 4483362458)
local BuyTab = Window:CreateTab("Auto Buy", 4483362458)
local SettingTab = Window:CreateTab("ตั้งค่าระบบ", 4483362458)

-- ฟังก์ชันค้นหา Economy
local function getMyEconomy()
    local myFolder = workspace:FindFirstChild("Buildings") and workspace.Buildings:FindFirstChild(Player.Name .. "Buildings")
    return myFolder and myFolder:FindFirstChild("Economy")
end

-------------------------------------------------------
-- [1] ระบบ Auto Rejoin (เมื่อโดนเตะจะเข้าใหม่ทันที)
-------------------------------------------------------
game:GetService("GuiService").ErrorMessageChanged:Connect(function()
    task.wait(5)
    TeleportService:Teleport(game.PlaceId, Player)
end)

-------------------------------------------------------
-- [2] ฟีเจอร์ประหยัดทรัพยากร (CPU/GPU Saver)
-------------------------------------------------------
SettingTab:CreateToggle({
   Name = "โหมดประหยัดพลังงาน (CPU Saver)",
   CurrentValue = false,
   Callback = function(Value)
      _G.CPUSaver = Value
      if Value then
         RunService:Set3dRenderingEnabled(false) -- ปิดการวาดภาพ 3D
         setfpscap(10) -- ลด FPS เหลือ 10
      else
         RunService:Set3dRenderingEnabled(true)
         setfpscap(60)
      end
   end,
})

SettingTab:CreateButton({
   Name = "ล้างขยะในแรมทันที (Manual GC)",
   Callback = function()
      collectgarbage("collect")
      Rayfield:Notify({Title = "System", Content = "ล้างหน่วยความจำเรียบร้อย", Duration = 2})
   end,
})

-------------------------------------------------------
-- [3] Auto Obby (150s + ล็อค 2 วิ)
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Obby",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoObby = Value
      if Value then
         task.spawn(function()
            while _G.AutoObby do
                local char = Player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local obbyWin = workspace:FindFirstChild("Obby") and workspace.Obby:FindFirstChild("ObbyWin")
                if root and obbyWin then
                    local oldPos = root.CFrame 
                    root.CFrame = obbyWin.CFrame
                    task.wait(1)
                    local startTime = tick()
                    while tick() - startTime < 2 do root.CFrame = oldPos task.wait() end
                end
                for i = 1, 150 do if not _G.AutoObby then break end task.wait(1) end
                collectgarbage("collect")
            end
         end)
      end
   end,
})

-------------------------------------------------------
-- [4] Auto Collect (อัปเดตค่า Real-time)
-------------------------------------------------------
MainTab:CreateToggle({
   Name = "Auto Collect Economy",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
         task.spawn(function()
            while _G.AutoCollect do
                local economy = getMyEconomy()
                if economy then
                    for _, b in pairs(economy:GetChildren()) do
                        if not _G.AutoCollect then break end
                        local prompt = b:FindFirstChild("CollectPrompt", true)
                        if prompt and prompt.ObjectText ~= "" then
                            local amnt, item = prompt.ObjectText:match("(%d+)%s+(.+)")
                            if amnt and tonumber(amnt) > 0 then
                                pcall(function() NetworkRemote:FireServer(buffer.fromstring("\018\001"), {{ b.Name, item, tonumber(amnt) }}) end)
                                task.wait(0.2)
                            end
                        end
                    end
                end
                task.wait(2)
                collectgarbage("collect")
            end
         end)
      end
   end,
})

