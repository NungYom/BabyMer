-------------------------------------------------------
-- [4] Auto Buy (เลือกสิ่งปลูกสร้างได้หลายรายการ)
-------------------------------------------------------
BuyTab:CreateDropdown({
   Name = "เลือกสิ่งปลูกสร้างที่จะซื้อ",
   Options = {"Small Cube", "Apartments", "Copper Mine", "Small Lake", "Library", "Gold Mine", "Diamond Mine", "Workshop", "Royal Castle", "War Castle", "Giant Cave", "Training Camp", "Mines Booster", "Clock", "Time Machine", "Unit Hut"},
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options)
      _G.SelectedBuildings = Options
   end,
})

BuyTab:CreateToggle({
   Name = "เปิดระบบ Auto Buy (5s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoBuy = Value
      if Value then
         task.spawn(function()
            while _G.AutoBuy do
                if #_G.SelectedBuildings > 0 then
                    for _, bName in pairs(_G.SelectedBuildings) do
                        local bCategory = BuildingMap[bName]
                        if bCategory then
                            pcall(function()
                                NetworkRemote:FireServer(buffer.fromstring("\020\001"), {{ bName, bCategory }})
                            end)
                            task.wait(0.1)
                        end
                    end
                end
                task.wait(5)
            end
         end)
      end
   end,
})
