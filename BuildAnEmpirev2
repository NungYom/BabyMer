-- ตัวแปรควบคุม
_G.AutoObby = false
_G.AutoCollect = false
_G.AutoSell = false
_G.AutoBuy = false
_G.SelectedBuildings = {}

-- ตารางคู่ ชื่อ-หมวดหมู่ (อัปเดต War Castle แล้ว)
