   CurrentValue = false,
   Callback = function(v) FocusBloater = v end,
})

MainTab:CreateSlider({
   Name = "ระยะการตรวจจับ (Studs)",
   Range = {0, 100}, Increment = 1, Suffix = " studs", CurrentValue = 50,
   Callback = function(v) DetectionRange1 = v end,
})

MainTab:CreateSlider({
   Name = "ตั้งค่าเลือดขั้นต่ำ",
   Range = {10, 100}, Increment = 1, Suffix = " HP", CurrentValue = 60,
   Callback = function(v) SafeHealth1 = v end,
})

MainTab:CreateToggle({
   Name = "เริ่มระบบ Auto Hunter",
   CurrentValue = false, Flag = "HunterToggle", 
   Callback = function(Value)
      HunterEnabled = Value
      if Value then
         local char = LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosHunter = root.Position end
      end
      
      task.spawn(function()
         local lastSwitch, lockedEnemy = 0, nil
         while HunterEnabled do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(LocalPlayer.Name)

            if root and hum and targetAttr and StartPosHunter then
                -- เรียกใช้งานระบบสลับอาวุธ
                HandleAutoEquip(root, hum)

                local hunger = targetAttr:GetAttribute("Hunger") or 100
                local explodingBloater = false
                local targetBloater = nil
                
                -- ตรวจจับศัตรูและ Bloater
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot then
                            local dist = (root.Position - bRoot.Position).Magnitude
                            local isExploding = bRoot:GetAttribute("Speed") == nil
                            if dist <= 30 and isExploding then explodingBloater = true end
                            if FocusBloater and not isExploding and (bRoot.Position - CenterPosHunter).Magnitude <= DetectionRange1 then
                                targetBloater = bRoot
                            end
                        end
                    end
                end

                -- ระบบกินอาหาร
                if hunger < 5 then IsEating1 = true EatTimer1 = 0
                elseif hunger >= 5 and IsEating1 then
                    if EatTimer1 == 0 then EatTimer1 = tick() + 2 end
                    if tick() >= EatTimer1 then IsEating1 = false end
                end

                -- กำหนดจุดหมาย (Target Point)
                local targetPoint = nil
                local isDanger = (explodingBloater or hum.Health < SafeHealth1)

                if isDanger then 
                    targetPoint = Vector3.new(CenterPosHunter.X, -20, CenterPosHunter.Z)
                elseif IsEating1 then
                    targetPoint = Vector3.new(StartPosHunter.X, -8, StartPosHunter.Z)
                elseif FocusBloater and targetBloater then
                    targetPoint = Vector3.new(targetBloater.Position.X, -7, targetBloater.Position.Z)
                else
                    -- ล็อคเป้าหมายศัตรูที่อยู่ไกลสุดในระยะ (Logic เดิม)
                    if tick() - lastSwitch >= 1 then
                        local maxD, furthest = -1, nil
                        for _, obj in pairs(charFolder:GetChildren()) do
                            if not Players:GetPlayerFromCharacter(obj) and not table.find(AllyList, obj.Name) and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and obj.Humanoid.Health > 0 then
                                local dFromCenter = (obj.HumanoidRootPart.Position - CenterPosHunter).Magnitude
                                if dFromCenter <= DetectionRange1 then
                                    local dMe = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                                    if dMe > maxD then maxD = dMe furthest = obj.HumanoidRootPart end
                                end
                            end
                        end
                        lockedEnemy = furthest lastSwitch = tick()
                    end
                    if lockedEnemy and lockedEnemy.Parent then 
                        targetPoint = Vector3.new(lockedEnemy.Position.X, -7, lockedEnemy.Position.Z)
                    else targetPoint = Vector3.new(CenterPosHunter.X, -7, CenterPosHunter.Z) end
                end

                -- การเคลื่อนที่แบบสมูท
                local isVertical = math.abs(root.Position.Y - targetPoint.Y) > 0.5
                local step = isVertical and 1 or (isDanger and 1 or 0.5)
                local waitTime = isVertical and 0.05 or (isDanger and 0.02 or 0.1)
                
                local dir = (targetPoint - root.Position)
                if dir.Magnitude > 0.1 then 
                    root.CFrame = CFrame.new(root.Position + dir.Unit * math.min(step, dir.Magnitude)) 
                end
                task.wait(waitTime)
            else task.wait(0.5) end
         end
      end)
   end,
})

