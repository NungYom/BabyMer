local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ultimate Farmer | v6 Pro Stable",
   LoadingTitle = "Fixing Logic Errors...",
   LoadingSubtitle = "by Gemini AI",
})

local MainTab = Window:CreateTab("Auto Hunter", 4483362458)
local SquareTab = Window:CreateTab("Square Loop Farm", 4483362458)

-- Config Shared
local AllyList = {"Survivor", "Scavenger", "Policeman", "Fighter", "Explorer", "Medic", "Farmer", "Fragger", "Guardian", "Engineer", "Hunter", "Assassin", "Soldier", "Berserker", "Necromancer", "Commander", "Psychic", "Merchant"}

-- State & Thresholds
local SafeHealth1, SafeHealth2 = 60, 60
local DetectionRange1 = 50 
local CenterPosHunter = Vector3.new(0, 7, 0) -- Default 0, 7, 0 ตามสั่ง

local HunterEnabled, SquareEnabled = false, false
local IsEating1, IsEating2 = false, false
local EatTimer1, EatTimer2 = 0, 0 -- ใช้เก็บเวลาแทนการ task.wait

local StartPosHunter, StartPosSquare = nil, nil
local TargetYLevel = -7
local LoopIndex = 1
local LoopPoints = {
    Vector3.new(0, 0, 50), Vector3.new(0, 0, -50),
    Vector3.new(50, 0, -50), Vector3.new(-50, 0, 50)
}

-- ฟังก์ชันคำนวณสปีด (Safe Logic)
local function GetMovementSettings(isDanger, isVerticalMoving)
    if isVerticalMoving then
        return 1, 0.05 -- ย้ายชั้น: 1 stud / 0.05s
    elseif isDanger then
        return 1, 0.02 -- Danger: 1 stud / 0.02s
    else
        return 0.5, 0.1 -- Normal: 0.5 stud / 0.1s
    end
end

-- ==========================================
-- หมวด 1: Auto Hunter
-- ==========================================
local CenterLabel = MainTab:CreateLabel("จุดศูนย์กลางปัจจุบัน: 0, 7, 0 (Default)")

MainTab:CreateButton({
   Name = "กำหนดจุดนี้เป็นจุดศูนย์กลาง (Fix Y -7)",
   Callback = function()
      local char = game.Players.LocalPlayer.Character
      local root = char and char:FindFirstChild("HumanoidRootPart")
      if root then
         CenterPosHunter = Vector3.new(root.Position.X, -7, root.Position.Z)
         CenterLabel:SetText(string.format("พิกัดศูนย์กลาง: %.1f, -7.0, %.1f", CenterPosHunter.X, CenterPosHunter.Z))
      end
   end,
})

MainTab:CreateSlider({
   Name = "ระยะการตรวจจับ (Studs)",
   Range = {0, 100}, Increment = 1, Suffix = " studs", CurrentValue = 50,
   Flag = "RangeSlider1", Callback = function(v) DetectionRange1 = v end,
})

MainTab:CreateSlider({
   Name = "ตั้งค่าเลือดขั้นต่ำ",
   Range = {10, 100}, Increment = 1, Suffix = " HP", CurrentValue = 60,
   Flag = "H1_Safe", Callback = function(v) SafeHealth1 = v end,
})

MainTab:CreateToggle({
   Name = "เริ่มระบบ Auto Hunter",
   CurrentValue = false, Flag = "HunterToggle", 
   Callback = function(Value)
      HunterEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosHunter = root.Position end
      end
      
      task.spawn(function()
         local lastSwitch, lockedEnemy = 0, nil
         while HunterEnabled do
            local player = game.Players.LocalPlayer
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosHunter then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                
                -- 1. เช็ค Bloater (แบบปลอดภัย v6 Adjusted Style)
                local isBloater = false
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (root.Position - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then isBloater = true break end
                        end
                    end
                end

                -- 2. Hunger Delay Logic (Non-blocking)
                if hunger < 5 then
                    IsEating1 = true
                    EatTimer1 = 0
                elseif hunger >= 5 and IsEating1 then
                    if EatTimer1 == 0 then EatTimer1 = tick() + 2 end -- ตั้งเวลาเป้าหมายล่วงหน้า 2 วิ
                    if tick() >= EatTimer1 then IsEating1 = false end
                end

                local targetPoint = nil
                local isDanger = (isBloater or hum.Health < SafeHealth1)

                -- 3. Target Selection
                if isDanger then 
                    -- จุดปลอดภัย: พิกัดศูนย์กลาง X, Z แกน Y = -20
                    targetPoint = Vector3.new(CenterPosHunter.X, -20, CenterPosHunter.Z)
                elseif IsEating1 then
                    targetPoint = Vector3.new(StartPosHunter.X, -8, StartPosHunter.Z)
                else
                    if tick() - lastSwitch >= 1 then
                        local maxD, furthest = -1, nil
                        for _, obj in pairs(charFolder:GetChildren()) do
                            if not game.Players:GetPlayerFromCharacter(obj) and not table.find(AllyList, obj.Name) and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and obj.Humanoid.Health > 0 then
                                local dFromCenter = (obj.HumanoidRootPart.Position - CenterPosHunter).Magnitude
                                if dFromCenter <= DetectionRange1 then
                                    local dMe = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                                    if dMe > maxD then maxD = dMe furthest = obj.HumanoidRootPart end
                                end
                            end
                        end
                        lockedEnemy = furthest lastSwitch = tick()
                    end
                    if lockedEnemy and lockedEnemy.Parent then 
                        targetPoint = Vector3.new(lockedEnemy.Position.X, -7, lockedEnemy.Position.Z)
                    else 
                        targetPoint = Vector3.new(CenterPosHunter.X, -7, CenterPosHunter.Z) 
                    end
                end

                local isVertical = math.abs(root.Position.Y - targetPoint.Y) > 0.5
                local step, waitTime = GetMovementSettings(isDanger, isVertical)
                local dir = (targetPoint - root.Position)
                if dir.Magnitude > 0.1 then 
                    root.CFrame = CFrame.new(root.Position + dir.Unit * math.min(step, dir.Magnitude)) 
                end
                task.wait(waitTime)
            else task.wait(0.5) end
         end
      end)
   end,
})

-- ==========================================
-- หมวด 2: Square Loop Farm
-- ==========================================
SquareTab:CreateSlider({
   Name = "ระดับแกน Y ตอนวนลูป",
   Range = {-20, -5}, Increment = 1, Suffix = " Y", CurrentValue = -7,
   Flag = "YLevel", Callback = function(v) TargetYLevel = v end,
})

SquareTab:CreateSlider({
   Name = "ตั้งค่าเลือดขั้นต่ำ",
   Range = {10, 100}, Increment = 1, Suffix = " HP", CurrentValue = 60,
   Flag = "H2_Safe", Callback = function(v) SafeHealth2 = v end,
})

SquareTab:CreateToggle({
   Name = "เริ่มระบบ Square Loop Farm",
   CurrentValue = false, Flag = "SquareToggle",
   Callback = function(Value)
      SquareEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosSquare = root.Position end
      end

      task.spawn(function()
         while SquareEnabled do
            local player = game.Players.LocalPlayer
            local char, root, hum = player.Character, player.Character:FindFirstChild("HumanoidRootPart"), player.Character:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosSquare then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                
                -- Bloater Check Safe
                local isBloater = false
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (root.Position - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then isBloater = true break end
                        end
                    end
                end

                -- Hunger Delay Logic (Non-blocking)
                if hunger < 5 then
                    IsEating2 = true
                    EatTimer2 = 0
                elseif hunger >= 5 and IsEating2 then
                    if EatTimer2 == 0 then EatTimer2 = tick() + 2 end
                    if tick() >= EatTimer2 then IsEating2 = false end
                end
                
                local isDanger = (isBloater or hum.Health < SafeHealth2)
                local finalTarget = nil

                if isDanger then 
                    local p = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(p.X, -20, p.Z)
                elseif IsEating2 then
                    finalTarget = Vector3.new(StartPosSquare.X, -8, StartPosSquare.Z)
                else 
                    local p = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(p.X, TargetYLevel, p.Z) 
                end

                local isVertical = math.abs(root.Position.Y - finalTarget.Y) > 0.5
                local step, waitTime = GetMovementSettings(isDanger, isVertical)

                if (Vector3.new(finalTarget.X, 0, finalTarget.Z) - Vector3.new(root.Position.X, 0, root.Position.Z)).Magnitude < 1 and not isDanger and not IsEating2 then
                    LoopIndex = LoopIndex + 1 if LoopIndex > #LoopPoints then LoopIndex = 1 end
                end

                local moveDir = (finalTarget - root.Position)
                if moveDir.Magnitude > 0.1 then root.CFrame = CFrame.new(root.Position + moveDir.Unit * math.min(step, moveDir.Magnitude)) end
                task.wait(waitTime)
            else task.wait(0.5) end
         end
      end)
   end,
})
