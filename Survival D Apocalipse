-- ==========================================
-- ระบบ Anti Lag (ตรวจจับและลบ Model ใน Workspace)
-- ==========================================
workspace.ChildAdded:Connect(function(child)
    if AntiLagEnabled then
        -- ตรวจสอบรายชื่อ Model ที่ระบุจากรูป
        if child.Name == "Spit" or child.Name == "Boulder" or child.Name == "BlightSpit" then
            task.delay(10, function()
                if child and child.Parent then
                    child:Destroy()
                end
            end)
        end
    end
end)

-- ==========================================
-- ฟังก์ชันช่วยเหลือ (Helper Functions)
-- ==========================================
local function GetToolList()
    local tools = {}
    -- ดึงจากกระเป๋า
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then table.insert(tools, tool.Name) end
    end
    -- ดึงจากมือที่ถืออยู่ใน Workspace
    local charFolder = workspace:FindFirstChild("Characters")
    local myChar = charFolder and charFolder:FindFirstChild(LocalPlayer.Name)
    if myChar then
        for _, tool in pairs(myChar:GetChildren()) do
            if tool:IsA("Tool") and not table.find(tools, tool.Name) then
                table.insert(tools, tool.Name)
            end
        end
    end
    return tools
end

-- ระบบสลับอาวุธแบบเสถียร (แก้ปัญหากดย้ำ)
local function HandleAutoEquip(root, hum)
    if not AutoEquipEnabled or not root or not hum then return end
    
    local charFolder = workspace:FindFirstChild("Characters")
    local myChar = charFolder and charFolder:FindFirstChild(LocalPlayer.Name) --
    
    local y = root.Position.Y
    local isInSafeZone = (y >= -22 and y <= -18)
    
    local targetWeapon = isInSafeZone and SelectedRanged or SelectedMelee
    local targetKey = isInSafeZone and Enum.KeyCode.Four or Enum.KeyCode.Two

    if targetWeapon == "" or targetWeapon == nil then return end

    -- ตรวจสอบว่า "ถืออยู่แล้ว" หรือไม่ ทั้งใน Workspace และ Character มาตรฐาน
    local isEquipped = (myChar and myChar:FindFirstChild(targetWeapon)) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(targetWeapon))

    -- ตรวจสอบว่าอาวุธ "อยู่ในกระเป๋า" หรือไม่
    local inBackpack = LocalPlayer.Backpack:FindFirstChild(targetWeapon)

    -- เงื่อนไข: ต้องไม่อยู่ในมือ และต้องมีของอยู่ในกระเป๋า ถึงจะกดปุ่ม
    if not isEquipped and inBackpack then
        if tick() - LastPressTime >= 1.5 then -- Cooldown 1.5 วิ ป้องกันการ Toggle ไปมา
            VIM:SendKeyEvent(true, targetKey, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, targetKey, false, game)
            LastPressTime = tick()
        end
    end
    
    -- ล็อคตัวไม่ให้หมุนเวลาถือปืนในเซฟโซน
    hum.AutoRotate = not isInSafeZone
end

