local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ultimate Farmer | Dual Mode v4",
   LoadingTitle = "Initializing Systems...",
   LoadingSubtitle = "by Gemini AI",
})

local MainTab = Window:CreateTab("Auto Hunter", 4483362458)
local SquareTab = Window:CreateTab("Square Loop Farm", 4483362458)

-- Variables Shared
local AllyList = {"Survivor", "Scavenger", "Policeman", "Fighter", "Explorer", "Medic", "Farmer", "Fragger", "Guardian", "Engineer", "Hunter", "Assassin", "Soldier", "Berserker", "Necromancer", "Commander", "Psychic", "Merchant"}

-- Mode 1 Variables
local HunterEnabled = false
local StartPosHunter = nil

-- Mode 2 Variables
local SquareEnabled = false
local StartPosSquare = nil
local TargetYLevel = -7 -- ค่าเริ่มต้นจาก Slider
local LoopIndex = 1
local LoopPoints = {
    Vector3.new(0, 0, 50),
    Vector3.new(0, 0, -50),
    Vector3.new(50, 0, -50),
    Vector3.new(-50, 0, 50)
}

-- ==========================================
-- หมวด 1: Auto Hunter (แบบเดิม)
-- ==========================================
MainTab:CreateToggle({
   Name = "เริ่มระบบ Auto Hunter (Far Target)",
   CurrentValue = false,
   Flag = "HunterToggle", 
   Callback = function(Value)
      HunterEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosHunter = root.Position end
      end
      
      task.spawn(function()
         local lastSwitch = 0
         local lockedEnemy = nil
         while HunterEnabled do
            local player = game.Players.LocalPlayer
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosHunter then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                local targetPoint = nil
                
                -- Priority & Logic (เหมือนเดิม)
                local isBloater = false
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (root.Position - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then isBloater = true break end
                        end
                    end
                end

                if tick() - lastSwitch >= 1 then
                    local furthest = nil
                    local maxD = -1
                    for _, obj in pairs(charFolder:GetChildren()) do
                        if not game.Players:GetPlayerFromCharacter(obj) and not table.find(AllyList, obj.Name) and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and obj.Humanoid.Health > 0 then
                            local dOrig = (obj.HumanoidRootPart.Position - Vector3.new(0,0,0)).Magnitude
                            if dOrig <= 100 then
                                local dMe = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                                if dMe > maxD then maxD = dMe furthest = obj.HumanoidRootPart end
                            end
                        end
                    end
                    lockedEnemy = furthest lastSwitch = tick()
                end

                if isBloater or hum.Health < 90 then targetPoint = Vector3.new(20, -20, 0)
                elseif hunger < 5 then targetPoint = Vector3.new(StartPosHunter.X, -8, StartPosHunter.Z)
                elseif lockedEnemy and lockedEnemy.Parent then targetPoint = Vector3.new(lockedEnemy.Position.X, -7, lockedEnemy.Position.Z)
                else targetPoint = Vector3.new(20, -20, 0) end

                if targetPoint then
                    local dir = (targetPoint - root.Position)
                    root.CFrame = CFrame.new(root.Position + (dir.Magnitude > 0.1 and dir.Unit * 1 or dir))
                end
            end
            task.wait(0.05)
         end
      end)
   end,
})

-- ==========================================
-- หมวด 2: Square Loop Farm (แบบใหม่)
-- ==========================================
SquareTab:CreateSlider({
   Name = "ระดับแกน Y ตอนวนลูป",
   Range = {-20, -5},
   Increment = 1,
   Suffix = " Y",
   CurrentValue = -7,
   Flag = "YLevelSlider",
   Callback = function(Value) TargetYLevel = Value end,
})

SquareTab:CreateToggle({
   Name = "เริ่มระบบ Square Loop Farm",
   CurrentValue = false,
   Flag = "SquareToggle",
   Callback = function(Value)
      SquareEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosSquare = root.Position end
      end

      task.spawn(function()
         while SquareEnabled do
            local player = game.Players.LocalPlayer
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosSquare then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                local currentPos = root.Position
                local finalTarget = nil
                
                -- 1. เช็คความปลอดภัย (Priority 1: Bloater & Priority 3: Health)
                local dangerDetected = false
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (currentPos - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then dangerDetected = true break end
                        end
                    end
                end
                if hum.Health < 90 then dangerDetected = true end

                -- 2. ตัดสินใจเลือกเป้าหมาย
                if dangerDetected then
                    -- โซนปลอดภัย: วนลูปที่ Y = -20
                    local point = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(point.X, -20, point.Z)
                elseif hunger < 5 then
                    -- Priority 2: หิว (ไปจุดเปิดเครื่อง Y = -8)
                    finalTarget = Vector3.new(StartPosSquare.X, -8, StartPosSquare.Z)
                else
                    -- ปกติ: วนลูปที่ Y ตาม Slider
                    local point = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(point.X, TargetYLevel, point.Z)
                end

                -- 3. ระบบเคลื่อนที่และเปลี่ยนจุด Loop
                local distToTarget = (Vector3.new(finalTarget.X, currentPos.Y, finalTarget.Z) - Vector3.new(currentPos.X, currentPos.Y, currentPos.Z)).Magnitude
                
                -- ถ้าหิวอยู่ จะไม่เปลี่ยน Index ของลูปสี่เหลี่ยม จนกว่าจะกินอิ่ม
                if distToTarget < 1 and hunger >= 5 and not dangerDetected then
                    LoopIndex = LoopIndex + 1
                    if LoopIndex > #LoopPoints then LoopIndex = 1 end
                end

                local moveDir = (finalTarget - currentPos)
                if moveDir.Magnitude > 0.1 then
                    root.CFrame = CFrame.new(currentPos + moveDir.Unit * 1)
                else
                    root.CFrame = CFrame.new(finalTarget)
                end
            end
            task.wait(0.05)
         end
      end)
   end,
})
