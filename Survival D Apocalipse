local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ultimate Auto-Combat | NPC Hunter",
   LoadingTitle = "Scanning Characters...",
   LoadingSubtitle = "by Gemini AI",
})

local MainTab = Window:CreateTab("Auto Hunter", 4483362458)
local DetectionEnabled = false
local StartPosition = nil 

MainTab:CreateToggle({
   Name = "เริ่มระบบ Auto Hunter (Smart Mode)",
   CurrentValue = false,
   Flag = "AutoHunterToggle", 
   Callback = function(Value)
      DetectionEnabled = Value
      
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then
            StartPosition = root.Position -- บันทึกจุดฟาร์ม (0,0,20)
         end
      end
      
      task.spawn(function()
         while DetectionEnabled do
            local player = game.Players.LocalPlayer
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChild("Humanoid")
            local characterFolder = workspace:FindFirstChild("Characters")
            local targetModel = characterFolder and characterFolder:FindFirstChild(player.Name)

            if rootPart and humanoid and targetModel and StartPosition then
                local currentHealth = humanoid.Health
                local currentHunger = targetModel:GetAttribute("Hunger") or 100
                local currentPos = rootPart.Position
                
                local targetPoint = nil -- จุดหมายปลายทางที่จะไป
                
                -- 1. [Priority 0] ตรวจจับ Bloater ระเบิด (ระยะ 30 studs, เลือด < 1)
                local isBloaterDanger = false
                for _, obj in pairs(characterFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bHum = obj:FindFirstChild("Humanoid")
                        local bRoot = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                        if bHum and bRoot and bHum.Health < 1 then
                            if (currentPos - bRoot.Position).Magnitude <= 30 then
                                isBloaterDanger = true
                                break
                            end
                        end
                    end
                end

                -- 2. [Priority 3] ค้นหาศัตรูที่ใกล้ที่สุด (ถ้าผ่านเงื่อนไขอื่นๆ)
                local closestEnemy = nil
                local minDistance = math.huge

                for _, obj in pairs(characterFolder:GetChildren()) do
                    -- คัดกรอง: ต้องไม่ใช่เรา, ไม่ใช่ผู้เล่นอื่น, และมี Humanoid
                    local isPlayer = game.Players:GetPlayerFromCharacter(obj)
                    local enemyHum = obj:FindFirstChild("Humanoid")
                    local enemyRoot = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")

                    if not isPlayer and enemyHum and enemyRoot and enemyHum.Health > 0 then
                        -- เงื่อนไข: ศัตรูต้องห่างจากจุด 0,0,0 ไม่เกิน 100 studs
                        local distFromOrigin = (enemyRoot.Position - Vector3.new(0, 0, 0)).Magnitude
                        if distFromOrigin <= 100 then
                            local distFromMe = (currentPos - enemyRoot.Position).Magnitude
                            if distFromMe < minDistance then
                                minDistance = distFromMe
                                closestEnemy = enemyRoot
                            end
                        end
                    end
                end

                -- 3. ตรรกะการเลือกจุดหมาย (Decision Making)
                if isBloaterDanger then
                    -- หนีระเบิด
                    targetPoint = Vector3.new(20, -20, 0)
                elseif currentHunger < 5 then
                    -- หิว: กลับจุดฟาร์มเดิมที่ Y = -8
                    targetPoint = Vector3.new(StartPosition.X, -8, StartPosition.Z)
                elseif currentHealth < 90 then
                    -- เลือดน้อย: พักโซนปลอดภัย
                    targetPoint = Vector3.new(20, -20, 0)
                elseif closestEnemy then
                    -- พบศัตรู: ไปอยู่ใต้ตัวมันที่ Y = -7
                    targetPoint = Vector3.new(closestEnemy.Position.X, -7, closestEnemy.Position.Z)
                else
                    -- ไม่เจอศัตรู: ไปรอที่จุดปลอดภัย
                    targetPoint = Vector3.new(20, -20, 0)
                end

                -- 4. ระบบค่อยๆ TP (0.1s ต่อ 1 stud)
                if targetPoint then
                    local moveDir = (targetPoint - currentPos)
                    if moveDir.Magnitude > 0.1 then
                        local nextPos = currentPos + moveDir.Unit * 1 -- ขยับทีละ 1 unit
                        rootPart.CFrame = CFrame.new(nextPos)
                    else
                        rootPart.CFrame = CFrame.new(targetPoint)
                    end
                end
            end
            
            task.wait(0.1) -- ความถี่ 0.1 วินาที
         end
      end)
   end,
})
