local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ultimate Farmer | Turbo Safety v5",
   LoadingTitle = "Adjusting Motor Speeds...",
   LoadingSubtitle = "by Gemini AI",
})

local MainTab = Window:CreateTab("Auto Hunter", 4483362458)
local SquareTab = Window:CreateTab("Square Loop Farm", 4483362458)

-- Shared Config
local AllyList = {"Survivor", "Scavenger", "Policeman", "Fighter", "Explorer", "Medic", "Farmer", "Fragger", "Guardian", "Engineer", "Hunter", "Assassin", "Soldier", "Berserker", "Necromancer", "Commander", "Psychic", "Merchant"}

-- Mode States
local HunterEnabled = false
local SquareEnabled = false
local StartPosHunter = nil
local StartPosSquare = nil
local TargetYLevel = -7
local LoopIndex = 1
local LoopPoints = {
    Vector3.new(0, 0, 50),
    Vector3.new(0, 0, -50),
    Vector3.new(50, 0, -50),
    Vector3.new(-50, 0, 50)
}

-- ฟังก์ชันคำนวณสปีดตามสถานะ
local function GetMovementSettings(isDanger)
    if isDanger then
        return 1, 0.02 -- เร่งสปีด: 1 stud ทุก 0.02 วิ
    else
        return 0.5, 0.1 -- ปกติ: 0.5 stud ทุก 0.1 วิ
    end
end

-- ==========================================
-- หมวด 1: Auto Hunter (Dynamic Speed)
-- ==========================================
MainTab:CreateToggle({
   Name = "เริ่มระบบ Auto Hunter",
   CurrentValue = false,
   Flag = "HunterToggle", 
   Callback = function(Value)
      HunterEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosHunter = root.Position end
      end
      
      task.spawn(function()
         local lastSwitch = 0
         local lockedEnemy = nil
         while HunterEnabled do
            local player = game.Players.LocalPlayer
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosHunter then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                local isBloater = false
                
                -- Check Bloater Speed Attribute
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (root.Position - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then isBloater = true break end
                        end
                    end
                end

                local isDanger = (isBloater or hum.Health < 90)
                local step, waitTime = GetMovementSettings(isDanger)
                local targetPoint = nil

                -- Target Logic
                if isDanger then targetPoint = Vector3.new(20, -20, 0)
                elseif hunger < 5 then targetPoint = Vector3.new(StartPosHunter.X, -8, StartPosHunter.Z)
                else
                    if tick() - lastSwitch >= 1 then
                        local furthest = nil
                        local maxD = -1
                        for _, obj in pairs(charFolder:GetChildren()) do
                            if not game.Players:GetPlayerFromCharacter(obj) and not table.find(AllyList, obj.Name) and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and obj.Humanoid.Health > 0 then
                                local dMe = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                                if dMe > maxD and (obj.HumanoidRootPart.Position - Vector3.new(0,0,0)).Magnitude <= 100 then
                                    maxD = dMe furthest = obj.HumanoidRootPart
                                end
                            end
                        end
                        lockedEnemy = furthest lastSwitch = tick()
                    end
                    if lockedEnemy and lockedEnemy.Parent then targetPoint = Vector3.new(lockedEnemy.Position.X, -7, lockedEnemy.Position.Z)
                    else targetPoint = Vector3.new(20, -20, 0) end
                end

                if targetPoint then
                    local dir = (targetPoint - root.Position)
                    if dir.Magnitude > 0.1 then
                        root.CFrame = CFrame.new(root.Position + dir.Unit * math.min(step, dir.Magnitude))
                    end
                end
                task.wait(waitTime)
            else
                task.wait(0.5)
            end
         end
      end)
   end,
})

-- ==========================================
-- หมวด 2: Square Loop Farm (Dynamic Speed)
-- ==========================================
SquareTab:CreateSlider({
   Name = "ระดับแกน Y ตอนวนลูป",
   Range = {-20, -5},
   Increment = 1,
   Suffix = " Y",
   CurrentValue = -7,
   Flag = "YLevelSlider",
   Callback = function(Value) TargetYLevel = Value end,
})

SquareTab:CreateToggle({
   Name = "เริ่มระบบ Square Loop Farm",
   CurrentValue = false,
   Flag = "SquareToggle",
   Callback = function(Value)
      SquareEnabled = Value
      if Value then
         local char = game.Players.LocalPlayer.Character
         local root = char and char:FindFirstChild("HumanoidRootPart")
         if root then StartPosSquare = root.Position end
      end

      task.spawn(function()
         while SquareEnabled do
            local player = game.Players.LocalPlayer
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local charFolder = workspace:FindFirstChild("Characters")
            local targetAttr = charFolder and charFolder:FindFirstChild(player.Name)

            if root and hum and targetAttr and StartPosSquare then
                local hunger = targetAttr:GetAttribute("Hunger") or 100
                
                -- ตรวจสอบสถานะอันตราย
                local isBloater = false
                for _, obj in pairs(charFolder:GetChildren()) do
                    if obj.Name == "Bloater" then
                        local bRoot = obj:FindFirstChild("HumanoidRootPart")
                        if bRoot and (root.Position - bRoot.Position).Magnitude <= 30 then
                            if bRoot:GetAttribute("Speed") == nil then isBloater = true break end
                        end
                    end
                end
                
                local isDanger = (isBloater or hum.Health < 90)
                local step, waitTime = GetMovementSettings(isDanger)
                local finalTarget = nil

                -- Decision Making
                if isDanger then
                    local p = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(p.X, -20, p.Z)
                elseif hunger < 5 then
                    finalTarget = Vector3.new(StartPosSquare.X, -8, StartPosSquare.Z)
                else
                    local p = LoopPoints[LoopIndex]
                    finalTarget = Vector3.new(p.X, TargetYLevel, p.Z)
                end

                -- Movement Logic
                local moveDir = (finalTarget - root.Position)
                local horizontalDist = (Vector3.new(finalTarget.X, 0, finalTarget.Z) - Vector3.new(root.Position.X, 0, root.Position.Z)).Magnitude
                
                -- เปลี่ยนจุด Loop เมื่อถึงเป้าหมายในแนวราบ และไม่อยู่ในภาวะหิวหรืออันตราย
                if horizontalDist < 1 and hunger >= 5 and not isDanger then
                    LoopIndex = LoopIndex + 1
                    if LoopIndex > #LoopPoints then LoopIndex = 1 end
                end

                if moveDir.Magnitude > 0.1 then
                    root.CFrame = CFrame.new(root.Position + moveDir.Unit * math.min(step, moveDir.Magnitude))
                end
                task.wait(waitTime)
            else
                task.wait(0.5)
            end
         end
      end)
   end,
})
