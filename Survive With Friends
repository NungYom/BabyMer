-- // Combat Logic // --
local function GetClosestMonster()
    local ClosestDistance = math.huge
    local Target = nil
    local EquippedTool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not EquippedTool or EquippedTool:GetAttribute("Ammo") == nil then return nil end
    local CharFolder = workspace:FindFirstChild("Characters")
    if not CharFolder then return nil end
    local MyRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not MyRoot then return nil end

    for _, v in pairs(CharFolder:GetChildren()) do
        if v ~= Player.Character and not Players:GetPlayerFromCharacter(v) and v.Name ~= "Merchant" and not v:FindFirstChild("Follow") then
            local Humanoid = v:FindFirstChild("Humanoid")
            local TargetPart = v:FindFirstChild(AimSettings.TargetPart)
            if Humanoid and TargetPart and Humanoid.Health > 0 then
                local DistanceFromPlayer = (MyRoot.Position - TargetPart.Position).Magnitude
                if DistanceFromPlayer <= AimSettings.MaxRange then
                    local ScreenPoint, OnScreen = Camera:WorldToViewportPoint(TargetPart.Position)
                    if OnScreen then
                        local MouseLocation = UserInputService:GetMouseLocation()
                        local DistanceFromMouse = (Vector2.new(MouseLocation.X, MouseLocation.Y) - Vector2.new(ScreenPoint.X, ScreenPoint.Y)).Magnitude
                        if DistanceFromMouse <= AimSettings.FOV then
                            if DistanceFromPlayer < ClosestDistance then
                                ClosestDistance = DistanceFromPlayer
                                Target = v
                            end
                        end
                    end
                end
            end
        end
    end
    return Target
end

local function ProcessAutoAttack()
    if not CombatSettings.AutoAttack then return end
    local Character = Player.Character
    if not Character then return end
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool or Tool:GetAttribute("ToolType") ~= "Melee" then return end
    local MyRoot = Character:FindFirstChild("HumanoidRootPart")
    if not MyRoot then return end
    local TargetsToHit = {}
    
    local CharFolder = workspace:FindFirstChild("Characters")
    if CharFolder then
        for _, v in pairs(CharFolder:GetChildren()) do
            if v ~= Character and not Players:GetPlayerFromCharacter(v) and v.Name ~= "Merchant" and not v:FindFirstChild("Follow") then
                local Hum = v:FindFirstChild("Humanoid")
                local Root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Head")
                if Hum and Hum.Health > 0 and Root then
                    if (MyRoot.Position - Root.Position).Magnitude <= CombatSettings.AttackRange then
                        table.insert(TargetsToHit, v)
                    end
                end
            end
        end
    end
    
    local StructFolder = workspace:FindFirstChild("Structures")
    if StructFolder then
        for _, v in pairs(StructFolder:GetChildren()) do
            if v.Name == "Scrap Pile" or v.Name == "Barrel" then
                local Primary = v:IsA("Model") and v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
                if Primary and (MyRoot.Position - Primary.Position).Magnitude <= CombatSettings.AttackRange then
                    table.insert(TargetsToHit, v)
                end
            end
        end
    end

    if #TargetsToHit > 0 then
        local SwingRemote = Tool:FindFirstChild("Swing")
        local HitRemote = Tool:FindFirstChild("HitTargets")
        if SwingRemote then SwingRemote:FireServer() end
        if HitRemote then HitRemote:FireServer(TargetsToHit) end
    end
end

local function CheckAndReload()
    if not CombatSettings.AutoReload then return end
    local Character = Player.Character
    if not Character then return end
    for _, Item in pairs(Character:GetChildren()) do
        if Item:IsA("Tool") and Item:GetAttribute("Ammo") ~= nil then
            if Item:GetAttribute("Ammo") <= 0 then
                local ReloadRemote = Item:FindFirstChild("Reload")
                if ReloadRemote and ReloadRemote:IsA("RemoteFunction") then ReloadRemote:InvokeServer() end
            end
        end
    end
end

-- // Farming & Other // --
local function ProcessCollection()
    local DroppedItems = workspace:FindFirstChild("DroppedItems")
    if not DroppedItems then return end
    local MyRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not MyRoot then return end
    for _, Item in pairs(DroppedItems:GetChildren()) do
        local ItemPos = Item:GetPivot().Position
        if ItemPos then
            local Distance = (MyRoot.Position - ItemPos).Magnitude
            if Distance <= CollectSettings.Range then
                local isFuel = (Item:GetAttribute("ItemType") or Item:GetAttribute("ToolType")) == "Fuel"
                if CollectSettings.PickUpEnabled and not isFuel then 
                    ReplicatedStorage.Remotes.Interaction.PickUpItem:FireServer(Item) 
                end
                if CollectSettings.BackpackEnabled then 
                    ReplicatedStorage.Remotes.Tools.AdjustBackpack:FireServer(Item) 
                end
                task.wait(CollectSettings.Delay)
            end
        end
    end
end

local function ProcessInstantOpen()
    if not OtherSettings.InstantOpen then return end
    local CratesFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Crates")
    if CratesFolder then
        for _, desc in pairs(CratesFolder:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
            end
        end
    end
end

-- // ESP Logic // --
local function CreateESP(part, isRandomCrate)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.Adornee = part
    highlight.FillColor = isRandomCrate and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 200, 50)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = part

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPInfo"
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 200, 0, 100)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Parent = billboard
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.TextColor3 = ESPSettings.TextColor
    textLabel.TextSize = ESPSettings.TextSize
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextStrokeTransparency = 0
    
    billboard.Parent = part
    return {Highlight = highlight, Label = textLabel, Billboard = billboard, IsCrate = isRandomCrate}
end

local function UpdateESP()
    for obj, data in pairs(ESPTable) do
        if not obj or not obj.Parent then
            data.Highlight:Destroy()
            data.Billboard:Destroy()
            ESPTable[obj] = nil
            continue
        end

        if ESPSettings.Enabled then
            local MyRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if MyRoot then
                local distance = math.floor((MyRoot.Position - obj:GetPivot().Position).Magnitude)
                local infoText = ""
                if data.IsCrate then
                    infoText = "\n[Random Crate]"
                else
                    local dropsFolder = obj:FindFirstChild("Drops")
                    if dropsFolder then
                        for _, val in pairs(dropsFolder:GetChildren()) do
                            infoText = infoText .. "\n- " .. tostring(val.Value)
                        end
                    end
                end
                data.Label.Text = string.format("%s\n[%d Studs]%s", obj.Name, distance, infoText)
                data.Highlight.Enabled = true
                data.Billboard.Enabled = true
            end
        else
            data.Highlight.Enabled = false
            data.Billboard.Enabled = false
        end
    end
end

