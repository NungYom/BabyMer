                    if hunger < 5 then IsEating1 = true EatTimer1 = 0
                    elseif hunger >= 5 and IsEating1 then
                        if EatTimer1 == 0 then EatTimer1 = tick() + 2 end
                        if tick() >= EatTimer1 then IsEating1 = false end
