-- // Power Plant Auto Farm Logic // --
local function GetPowerBoxes()
    local Boxes = {}
    local Tiles = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Tiles")
    if Tiles then
        for _, tile in pairs(Tiles:GetChildren()) do
            local Box = tile:FindFirstChild("Power Box")
            if Box then table.insert(Boxes, Box) end
        end
    end
    return Boxes
end

local function ProcessPowerFixing()
    if not (OtherSettings.InstantFixing or OtherSettings.AutoFarmPower) then return end
    local Boxes = GetPowerBoxes()
    for _, box in pairs(Boxes) do
        local Prompt = box:FindFirstChild("Prompt")
        if Prompt then Prompt.HoldDuration = 0 end
    end
end

task.spawn(function()
    while true do
        if OtherSettings.AutoFarmPower then
            local Character = Player.Character
            local Root = Character and Character:FindFirstChild("HumanoidRootPart")
            local Hum = Character and Character:FindFirstChildOfClass("Humanoid")
            if Root and Hum then
                local Boxes = GetPowerBoxes()
