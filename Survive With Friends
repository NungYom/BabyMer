-- // [Core Logic] Hitbox Expander Function // --
local function UpdateHitboxes()
    local CharFolder = workspace:FindFirstChild("Characters")
    if not CharFolder then return end

    for _, v in pairs(CharFolder:GetChildren()) do
        if v ~= Player.Character and not Players:GetPlayerFromCharacter(v) and v.Name ~= "Merchant" and not v:FindFirstChild("Follow") then
            local Head = v:FindFirstChild("Head")
            if Head and Head:IsA("BasePart") then
                if HitboxSettings.Enabled then
                    Head.Size = Vector3.new(HitboxSettings.Size, HitboxSettings.Size, HitboxSettings.Size)
                    Head.Transparency = 0.5
                    Head.CanCollide = false
                else
                    Head.Size = Vector3.new(1.2, 1.2, 1.2)
                    Head.Transparency = 0
                    Head.CanCollide = true
                end
            end
        end
    end
end

-- // [Logic] ESP สำหรับ Dropped Items // --
local function CreateDroppedESP(part)
    local itemType = part:GetAttribute("ItemType") or part:GetAttribute("ToolType") or "Item"
    local itemColor = Color3.fromRGB(255, 255, 255)
    
    if itemType == "Resource" then itemColor = Color3.fromRGB(112, 128, 144)
    elseif itemType == "Fuel" then itemColor = Color3.fromRGB(255, 140, 0)
    elseif itemType == "Medical" then itemColor = Color3.fromRGB(151, 0, 0)
    elseif itemType == "Food" then itemColor = Color3.fromRGB(184, 134, 11)
    elseif itemType == "Melee" then itemColor = Color3.fromRGB(148, 0, 211)
    elseif itemType == "Gun" then itemColor = Color3.fromRGB(91, 154, 76) 
    elseif itemType == "Throwable" then itemColor = Color3.fromRGB(107, 50, 124) 
    elseif itemType == "Ammo" then itemColor = Color3.fromRGB(255, 215, 0)
    elseif itemType == "Blueprint" then itemColor = Color3.fromRGB(0, 0, 205)
    elseif itemType == "Armor" then itemColor = Color3.fromRGB(109, 110, 108) 
    end

    local highlight = Instance.new("Highlight")
    highlight.Adornee = part
    highlight.FillColor = itemColor
    highlight.FillTransparency = 0.6
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = part

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 150, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 2, 0)
    
    local textLabel = Instance.new("TextLabel", billboard)
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.TextColor3 = itemColor
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextStrokeTransparency = 0
    
    billboard.Parent = part
    return {Highlight = highlight, Label = textLabel, Billboard = billboard}
end

