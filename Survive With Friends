RunService.RenderStepped:Connect(function()
    FOVCircle.Position = UserInputService:GetMouseLocation()
    if MovementSettings.WalkSpeedEnabled and Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = MovementSettings.WalkSpeed
    end
    if AimSettings.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local Target = GetClosestMonster()
        if Target then
            local TargetPos = Target[AimSettings.TargetPart].Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, TargetPos), AimSettings.Smoothness)
        end
    end
    CheckAndReload()
end)

workspace.ChildAdded:Connect(function(child)
    if AntiLagEnabled then
        if child.Name == "Spit" or child.Name == "Boulder" or child.Name == "BlightSpit" then
            task.delay(10, function() if child and child.Parent then child:Destroy() end end)
        end
    end
end)

task.spawn(function()
    while true do
        UpdateHitboxes()
        if CombatSettings.AutoAttack then ProcessAutoAttack() end
        if CollectSettings.PickUpEnabled or CollectSettings.BackpackEnabled then ProcessCollection() end
        if OtherSettings.InstantOpen or OtherSettings.InstantFixing or OtherSettings.AutoFarmPower then 
            ProcessInstantOpen() 
            ProcessPowerFixing()
        end
        
        if ESPSettings.Enabled then
            local Structures = workspace:FindFirstChild("Structures")
            if Structures then
                for _, obj in pairs(Structures:GetChildren()) do
                    if obj:FindFirstChild("Drops") and not ESPTable[obj] then ESPTable[obj] = CreateESP(obj, false) end
                end
            end
            local Crates = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Crates")
            if Crates then
                for _, crate in pairs(Crates:GetChildren()) do
                    if crate:FindFirstChild("Prompt") and not ESPTable[crate] then ESPTable[crate] = CreateESP(crate, true) end
                end
            end
        end
        UpdateESP()

        local DroppedFolder = workspace:FindFirstChild("DroppedItems")
        if DroppedESPSettings.Enabled and DroppedFolder then
            for _, item in pairs(DroppedFolder:GetChildren()) do
                local currentItemType = item:GetAttribute("ItemType") or item:GetAttribute("ToolType") or "None"
                local isTarget = table.find(DroppedESPSettings.TargetTypes, "All") or table.find(DroppedESPSettings.TargetTypes, currentItemType)
                
                if isTarget then
                    if not DroppedESPTable[item] then DroppedESPTable[item] = CreateDroppedESP(item) end
                    local data = DroppedESPTable[item]
                    local MyRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if MyRoot and data and data.Label then
                        local dist = math.floor((MyRoot.Position - item:GetPivot().Position).Magnitude)
                        data.Label.Text = string.format("%s\n[%d Studs]", item.Name, dist)
                        data.Highlight.Enabled = true
                        data.Billboard.Enabled = true
                    end
                elseif DroppedESPTable[item] then
                    DroppedESPTable[item].Highlight.Enabled = false
                    DroppedESPTable[item].Billboard.Enabled = false
                end
            end
        end
        for item, data in pairs(DroppedESPTable) do
            if not item or not item.Parent or not DroppedESPSettings.Enabled then
                if data.Highlight then data.Highlight:Destroy() end
                if data.Billboard then data.Billboard:Destroy() end
                DroppedESPTable[item] = nil
            end
        end
        task.wait(0.5)
    end
end)

