local function CreateDroppedESP(part)
    local itemType = part:GetAttribute("ItemType") or part:GetAttribute("ToolType") or "Item"
    local itemColor = Color3.fromRGB(255, 255, 255)
    
    if itemType == "Resource" then itemColor = Color3.fromRGB(112, 128, 144)
    elseif itemType == "Fuel" then itemColor = Color3.fromRGB(255, 140, 0)
    elseif itemType == "Medical" then itemColor = Color3.fromRGB(151, 0, 0)
    elseif itemType == "Food" then itemColor = Color3.fromRGB(184, 134, 11)
    elseif itemType == "Melee" then itemColor = Color3.fromRGB(148, 0, 211)
    elseif itemType == "Gun" then itemColor = Color3.fromRGB(91, 154, 76) 
    elseif itemType == "Throwable" then itemColor = Color3.fromRGB(107, 50, 124) 
    elseif itemType == "Ammo" then itemColor = Color3.fromRGB(255, 215, 0)
    elseif itemType == "Blueprint" then itemColor = Color3.fromRGB(0, 0, 205)
    elseif itemType == "Armor" then itemColor = Color3.fromRGB(109, 110, 108) 
    end

    local highlight = Instance.new("Highlight")
    highlight.Adornee = part
    highlight.FillColor = itemColor
    highlight.FillTransparency = 0.6
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
