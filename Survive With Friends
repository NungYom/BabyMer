                    if isDangerHP or isExplodingNear then targetPoint = Vector3.new(CenterPosHunter.X, -20, CenterPosHunter.Z)
                    elseif IsEating1 then targetPoint = Vector3.new(StartPosHunter.X, -8, StartPosHunter.Z)
