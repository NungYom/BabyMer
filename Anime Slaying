local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Professional Auto-Farm | Rayfield",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by Expert Scripter",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "AutoFarmConfig",
      FileName = "MainConfig"
   }
})

-- Variables
local _G = {
    AutoAttackNearest = false,
    AutoAttackAll = false,
    AttackSpeed = 0 
}

local Player = game.Players.LocalPlayer
local Remote = game:GetService("ReplicatedStorage"):WaitForChild("CommonLibrary"):WaitForChild("Tool"):WaitForChild("RemoteManager"):WaitForChild("Funcs"):WaitForChild("DataPullFunc")
local MonsterFolder = workspace:WaitForChild("ClientMonsters")

-- Function: ดึง ID จากชื่อมอนสเตอร์
local function getMonsterID(monsterName)
    return tonumber(string.match(monsterName, "%d+"))
end

-- Function: ค้นหามอนสเตอร์ที่ใกล้ที่สุด
local function getNearestMonsterID()
    local nearestID = nil
    local shortestDistance = math.huge

    for _, monster in pairs(MonsterFolder:GetChildren()) do
        local rootPart = monster:FindFirstChild("HumanoidRootPart") or monster:FindFirstChildWhichIsA("BasePart")
        if rootPart then
            local distance = (Player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
            if distance < shortestDistance then
                local id = getMonsterID(monster.Name)
                if id then
                    shortestDistance = distance
                    nearestID = id
                end
            end
        end
    end
    return nearestID
end

-- Main Tab
local Tab = Window:CreateTab("Combat", 4483362458)

-- ปุ่ม 1: ตีตัวที่ใกล้ที่สุด (เดิม)
Tab:CreateToggle({
   Name = "Auto Attack (Nearest)",
   CurrentValue = false,
   Flag = "NearestToggle",
   Callback = function(Value)
      _G.AutoAttackNearest = Value
      if Value then
          task.spawn(function()
              while _G.AutoAttackNearest do
                  local targetID = getNearestMonsterID()
                  if targetID then
                      pcall(function()
                          Remote:InvokeServer("AttackMonsterChannel", {targetID})
                      end)
                  end
                  task.wait(_G.AttackSpeed)
              end
          end)
      end
   end,
})

-- ปุ่ม 2: ตีทุกตัวในเซิร์ฟเวอร์ (ใหม่!)
Tab:CreateToggle({
   Name = "Auto Attack (All Monsters)",
   CurrentValue = false,
   Flag = "AllToggle",
   Callback = function(Value)
      _G.AutoAttackAll = Value
      if Value then
          task.spawn(function()
              while _G.AutoAttackAll do
                  -- วนลูปตีมอนสเตอร์ทุกตัวที่มีอยู่ใน Folder
                  for _, monster in pairs(MonsterFolder:GetChildren()) do
                      if not _G.AutoAttackAll then break end -- ตรวจสอบว่าปิด Toggle หรือยัง
                      
                      local targetID = getMonsterID(monster.Name)
                      if targetID then
                          pcall(function()
                              Remote:InvokeServer("AttackMonsterChannel", {targetID})
                          end)
                      end
                      -- ใส่ wait เล็กน้อยเพื่อไม่ให้ Remote โดนเตะ (Spam Protection)
                      -- ถ้าอยากให้รัวสุดๆ ให้ปรับเป็น task.wait() หรือใส่ค่า 0
                  end
                  task.wait(_G.AttackSpeed)
              end
          end)
      end
   end,
})

