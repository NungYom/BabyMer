-- [[ Core Logic: ระบบประมวลผลหลัก ]]

-- Killer Logic (Q)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if input.KeyCode == Enum.KeyCode.Q and killerMode then
        if not targetPlayer then
            -- หาเป้าหมาย
            local closest, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist then dist = d; closest = v end
                end
            end
            
            if closest then
                targetPlayer = closest
                local conn
                conn = RunService.Heartbeat:Connect(function()
                    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and killerMode then
                        hrp.Velocity = Vector3.new(0,0,0)
                        hrp.CFrame = getOrbitCFrame(targetPlayer.Character.HumanoidRootPart)
                    else
                        conn:Disconnect()
                        targetPlayer = nil
                        safeReturn()
                    end
                end)
            end
        else
            targetPlayer = nil
            task.wait(0.1)
            safeReturn()
        end
    end

    -- Loot Logic (R)
    if input.KeyCode == Enum.KeyCode.R and lootMode then
        if not isLooting then
            isLooting = true
            task.spawn(function()
                while isLooting and lootMode do
                    local closest, dist = nil, lootMaxDist
                    for _, v in pairs(workspace.Loot:GetChildren()) do
                        if v.Name == "Bottle" or v.Name == "Bread" then
                            local h = v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")
                            if h then
                                local d = (h.Position - hrp.Position).Magnitude
                                if d < dist then dist = d; closest = v end
                            end
                        end
                    end
                    
                    if closest then
                        local h = closest:FindFirstChild("Handle") or closest:FindFirstChildWhichIsA("BasePart")
                        -- Tween ไปหาของ (ความเร็วสัมพันธ์กับ WalkSpeed)
                        local moveTime = dist / speedValue
                        local tween = TweenService:Create(hrp, TweenInfo.new(moveTime, Enum.EasingStyle.Linear), {CFrame = h.CFrame * CFrame.new(0, -2, 0)})
                        tween:Play()
                        
                        -- รอจนกว่าจะถึงหรือของหาย
                        local reached = false
                        tween.Completed:Connect(function() reached = true end)
                        while not reached and isLooting do
                            if not closest or not closest.Parent then tween:Cancel(); break end
                            task.wait()
                        end
                        
                        if isLooting and closest and closest.Parent then
                            VirtualInputManager:SendKeyEvent(true, "E", false, game)
                            local t = 0
                            while t < 0.8 do
                                if not closest or not closest.Parent or not isLooting then break end
                                task.wait(0.05); t = t + 0.05
                            end
                            VirtualInputManager:SendKeyEvent(false, "E", false, game)
                        end
                    else
                        isLooting = false
                    end
                    task.wait(0.1)
                end
                safeReturn()
            end)
        else
            isLooting = false
            task.wait(0.1)
            safeReturn()
        end
    end
end)

-- Loop Speed
RunService.Stepped:Connect(function()
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = speedValue
    end
end)
