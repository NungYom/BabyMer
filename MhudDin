-- [[ Variables ]]
local killerMode, lootMode, isLooting, espEnabled = false, false, false, false
local targetPlayer = nil
local speedValue = 35
local tpOffset = 2
local orbitRadius = 2 -- ระยะห่างจากศูนย์กลางเป้าหมาย
local orbitSpeed = 300 -- ความเร็วในการหมุน
local lootMaxDist = 5000 -- ระยะตรวจจับอาหาร (ไกลมาก)

-- [[ Functions: ระบบพื้นฐาน ]]

-- ระบบหาพื้นดินที่ปลอดภัย (Raycast จากฟ้าลงมา)
local function safeReturn()
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local rayOrigin = hrp.Position + Vector3.new(0, 100, 0)
    local rayDirection = Vector3.new(0, -200, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Player.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    local targetY = result and result.Position.Y + 3 or hrp.Position.Y + 10
    
    local tween = TweenService:Create(hrp, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {
        CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
    })
    tween:Play()
end

-- ระบบหมุนรอบเป้าหมาย (แก้เรื่อง Ping/Hitbox)
local function getOrbitCFrame(targetHRP)
    local angle = tick() * (orbitSpeed / 50)
    local offset = Vector3.new(math.cos(angle) * orbitRadius, -tpOffset, math.sin(angle) * orbitRadius)
    return CFrame.new(targetHRP.Position + offset, targetHRP.Position + Vector3.new(0, 5, 0))
    -- CFrame.new(ตำแหน่งเรา, ตำแหน่งที่มอง) -> ทำให้เราหันหน้าหาเป้าหมายตลอดแม้นอนหงาย
end

