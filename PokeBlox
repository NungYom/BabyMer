local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if game.PlaceId ~= 106763540857326 then warn("Wrong Game!") return end

local Window = Rayfield:CreateWindow({
    Name = "Auto Hunt Professional | Sequence Mode",
    LoadingTitle = "Initializing Sequence Logic...",
    ConfigurationSaving = { Enabled = true, FileName = "AutoHunt_Sequence" }
})

local Tab = Window:CreateTab("Main", "sword")
local AutoHuntToggle = true

-- ปุ่ม Numpad Minus (0x21)
local function TriggerIYSkyHop()
    keypress(0x21)
    task.wait(0.2)
    keyrelease(0x21)
end

local function ExecuteHop()
    warn("ครบทั้ง 4 จุดแล้วไม่พบมอนสเตอร์ - กำลัง Hop Server...")
    for i = 1, 10 do
        TriggerIYSkyHop()
        task.wait(1)
    end
end

local function GetNearestMob(origin, radius)
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    local client = live:FindFirstChild("Mobs") and live.Mobs:FindFirstChild("Client")
    if not client then return nil end
    
    for _, mob in pairs(client:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - origin).Magnitude <= radius then
            return hrp
        end
    end
    return nil
end

local function RunLogic()
    local waypoints = {
        CFrame.new(932.93, 28.87, -1472.02),
        CFrame.new(893.79, 28.48, -1341.54),
        CFrame.new(1574.43, 26.53, 1904.87),
        CFrame.new(1378.69, 42.22, 1679.54)
    }

    while AutoHuntToggle do
        local success, err = pcall(function()
            local foundAnyMob = false
            
            -- วนเช็คทั้ง 4 จุด
            for _, pos in pairs(waypoints) do
                if not AutoHuntToggle then break end
                
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char:PivotTo(pos)
                    task.wait(2)
                    
                    -- ตีจนกว่าจะไม่มีมอนในจุดนั้น
                    local startTimer = tick()
                    while AutoHuntToggle do
                        local mob = GetNearestMob(pos.Position, 50)
                        if mob then
                            foundAnyMob = true -- เจอว่ามีมอนอยู่ในอย่างน้อย 1 จุด
                            startTimer = tick() -- รีเซ็ตเวลาถอยหลัง
                            task.wait(1)
                        else
                            -- ถ้าไม่เจอเลยเกิน 3 วินาที ให้ไปจุดถัดไป
                            if (tick() - startTimer) >= 3 then break end
                            task.wait(0.5)
                        end
                    end
                end
            end
            
            -- ถ้าวนครบ 4 จุดแล้วไม่เจออะไรเลยค่อย Hop
            if AutoHuntToggle and not foundAnyMob then
                ExecuteHop()
                task.wait(15)
            end
        end)
        
        if not success then
            warn("Loop Error: " .. tostring(err))
            task.wait(5)
        end
    end
end

-- UI Setup
Tab:CreateToggle({
    Name = "Auto Hunt (Sequence Mode)",
    CurrentValue = true,
    Callback = function(Value)
        AutoHuntToggle = Value
        if AutoHuntToggle then task.spawn(RunLogic) end
    end,
})

task.spawn(RunLogic)
