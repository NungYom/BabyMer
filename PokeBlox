local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if game.PlaceId ~= 106763540857326 then warn("Wrong Game!") return end

local Window = Rayfield:CreateWindow({
    Name = "Auto Hunt Professional | Patrol Mode",
    LoadingTitle = "Initializing Patrol Logic...",
    ConfigurationSaving = { Enabled = true, FileName = "AutoHunt_Patrol" }
})

local Tab = Window:CreateTab("Main", "sword")
local AutoHuntToggle = true

-- ฟังก์ชันกดปุ่มทั้ง 2 รูปแบบ
local function TriggerHopSignals()
    -- Numpad Minus (0x6D)
    keypress(0x6D)
    task.wait(0.2)
    keyrelease(0x6D)
    
    task.wait(0.5)
    
    -- Page Up (0x21)
    keypress(0x21)
    task.wait(0.2)
    keyrelease(0x21)
end

local function ExecuteHop()
    warn("ครบ 4 จุดแล้ว - กำลัง Hop Server (Dual Signal)...")
    for i = 1, 5 do -- ลดจำนวนลูปเหลือ 5 รอบ แต่กด 2 ปุ่มจะทำให้โอกาสติดสูงขึ้น
        TriggerHopSignals()
        task.wait(1)
    end
end

local function GetNearestMob(origin, radius)
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    local client = live:FindFirstChild("Mobs") and live.Mobs:FindFirstChild("Client")
    if not client then return nil end
    
    for _, mob in pairs(client:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - origin).Magnitude <= radius then
            return hrp
        end
    end
    return nil
end

local function RunLogic()
    local waypoints = {
        CFrame.new(932.93, 28.87, -1472.02),
        CFrame.new(893.79, 28.48, -1341.54),
        CFrame.new(1574.43, 26.53, 1904.87),
        CFrame.new(1378.69, 42.22, 1679.54)
    }

    while AutoHuntToggle do
        local success, err = pcall(function()
            -- วนลูปครบ 4 จุด
            for _, pos in pairs(waypoints) do
                if not AutoHuntToggle then break end
                
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char:PivotTo(pos)
                    task.wait(1.5) -- ดีเลย์หลัง TP ให้โลกโหลด
                    
                    -- ตรวจมอน 1 วินาที ถ้าเจอให้ตีจนกว่าจะหมด
                    local timeout = tick() + 30 -- กันค้างในจุดเดียวเกิน 30 วิ
                    while AutoHuntToggle and tick() < timeout and GetNearestMob(pos.Position, 50) do
                        task.wait(1)
                    end
                end
            end
            
            -- ครบ 4 จุดแล้ว Hop ทันที
            if AutoHuntToggle then
                ExecuteHop()
                task.wait(20)
            end
        end)
        
        if not success then
            warn("Patrol Error: " .. tostring(err))
            task.wait(5)
        end
    end
end

-- UI Setup
Tab:CreateToggle({
    Name = "Auto Hunt (Patrol Mode)",
    CurrentValue = true,
    Callback = function(Value)
        AutoHuntToggle = Value
        if AutoHuntToggle then task.spawn(RunLogic) end
    end,
})

task.spawn(RunLogic)
