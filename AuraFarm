local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- [[ 1. สร้าง ScreenGui ]]
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CustomFarmGui"
screenGui.ResetOnSpawn = false -- ตายแล้ว GUI ไม่หาย
screenGui.Parent = player:WaitForChild("PlayerGui")

-- [[ 2. ฟังก์ชันสร้างปุ่ม (ใช้สไตล์ตามที่คุณส่งมา) ]]
local function createButton(name, pos, color)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 180, 0, 45)
    btn.Position = pos
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 18
    btn.Parent = screenGui

    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, 10)
    uiCorner.Parent = btn
    
    return btn
end

-- วางปุ่ม 3 ปุ่มเรียงกันทางด้านขวาของจอ (หรือปรับ Position ตามชอบ)
local btnLock = createButton("LockPos", UDim2.new(0.8, 0, 0.4, 0), Color3.fromRGB(100, 100, 100))
local btnFlag = createButton("FlagFarm", UDim2.new(0.8, 0, 0.5, 0), Color3.fromRGB(100, 100, 100))
local btnAuto = createButton("AutoFarm", UDim2.new(0.8, 0, 0.6, 0), Color3.fromRGB(100, 100, 100))

-- [[ 3. ตัวแปรสถานะ ]]
local mode = "None"
local savedCFrame = nil

-- [[ 4. ฟังก์ชันค้นหาพิกัดตามเงื่อนไข (Priority System) ]]
local function getTarget()
    local zones = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Zones")
    if not zones then return nil end

    if mode == "Lock" then
        return savedCFrame
    elseif mode == "Flag" then
        local flag = zones:FindFirstChild("FlagZone")
        return flag and (flag.CFrame * CFrame.new(0, -3, 0))
    elseif mode == "Auto" then
        -- ลำดับ Priority: 4X -> 3X -> 2X
        local prio = {"4XAura", "3XAura", "2XAura"}
        for _, name in ipairs(prio) do
            local zoneFolder = zones:FindFirstChild(name)
            if zoneFolder then
                local hitBox = zoneFolder:FindFirstChild("HitBox")
                if hitBox then return hitBox.CFrame end
            end
        end
        -- ถ้าไม่เจอ Aura เลย ให้ไป FlagZone (Y-3)
        local flag = zones:FindFirstChild("FlagZone")
        return flag and (flag.CFrame * CFrame.new(0, -3, 0))
    end
    return nil
end

-- [[ 5. ระบบ Loop TP แบบนิ่งสนิท (Physics Lock) ]]
RunService.Stepped:Connect(function()
    if mode == "None" then return end
    
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local target = getTarget()
    if target then
        root.CFrame = target
        -- ล้างความเร็วเพื่อความนิ่ง ใครผลักก็ไม่ขยับ
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
end)

-- [[ 6. ระบบจัดการปุ่มสลับสถานะ (Toggle) ]]
local function resetButtons()
    btnLock.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    btnLock.Text = "LockPos: OFF"
    btnFlag.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    btnFlag.Text = "FlagFarm: OFF"
    btnAuto.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    btnAuto.Text = "AutoFarm: OFF"
end

btnLock.MouseButton1Click:Connect(function()
    if mode == "Lock" then
        mode = "None"
        resetButtons()
    else
        mode = "Lock"
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then savedCFrame = root.CFrame end -- จำพิกัดปัจจุบัน
        resetButtons()
        btnLock.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        btnLock.Text = "LockPos: ON"
    end
end)

btnFlag.MouseButton1Click:Connect(function()
    if mode == "Flag" then
        mode = "None"
        resetButtons()
    else
        mode = "Flag"
        resetButtons()
        btnFlag.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        btnFlag.Text = "FlagFarm: ON"
    end
end)

btnAuto.MouseButton1Click:Connect(function()
    if mode == "Auto" then
        mode = "None"
        resetButtons()
    else
        mode = "Auto"
        resetButtons()
        btnAuto.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        btnAuto.Text = "AutoFarm: ON"
    end
end)
