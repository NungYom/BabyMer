local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- [[ 1. สร้าง ScreenGui ]]
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FinalFarmGui_V4"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

-- [[ 2. ฟังก์ชันสร้างปุ่ม ]]
local function createButton(name, pos, color)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 180, 0, 45)
    btn.Position = pos
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 18
    btn.Parent = screenGui
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    return btn
end

local btnLock = createButton("LockPos", UDim2.new(0.8, 0, 0.4, 0), Color3.fromRGB(80, 80, 80))
local btnFlag = createButton("FlagFarm", UDim2.new(0.8, 0, 0.5, 0), Color3.fromRGB(80, 80, 80))
local btnAuto = createButton("AutoFarm", UDim2.new(0.8, 0, 0.6, 0), Color3.fromRGB(80, 80, 80))

-- [[ 3. ตัวแปรสถานะ ]]
local mode = "None"
local savedCFrame = nil
local FARM_Y_HEIGHT = 3.5 -- ระดับแกน Y ขณะฟาร์ม (ปรับให้พอดีพื้น)
local EXIT_Y_HEIGHT = 5 -- ระดับแกน Y เมื่อกดปิดเพื่อโผล่บนดิน

-- [[ 4. ฟังก์ชันจัดการ Humanoid ]]
local function fixHumanoid(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
end

player.CharacterAdded:Connect(fixHumanoid)
if player.Character then fixHumanoid(player.Character) end

-- [[ 5. ฟังก์ชันค้นหาเป้าหมาย ]]
local function getTarget()
    local zones = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Zones")
    if not zones then return nil end

    if mode == "Lock" then
        return savedCFrame
    elseif mode == "Flag" then
        local flag = zones:FindFirstChild("FlagZone")
        -- ใช้พิกัดเดิมของคุณ (4, -11.2, 0)
        return flag and (flag.CFrame * CFrame.new(4, -11.2, 0))
        
    elseif mode == "Auto" then
        -- ลำดับ Priority ตามที่คุณต้องการ
        local priorities = {"10XAura", "5XAura", "4XAura", "3XAura", "2XAura"}
        
        for _, name in ipairs(priorities) do
            local zone = zones:FindFirstChild(name)
            if zone then
                local hb = zone:FindFirstChild("Hitbox") or zone:FindFirstChild("HitBox")
                if hb then
                    -- ล็อกพิกัด X, Z ของ Aura แต่ใช้แกน Y สำหรับฟาร์ม
                    return CFrame.new(hb.Position.X, FARM_Y_HEIGHT, hb.Position.Z)
                end
            end
        end
        
        -- ถ้าไม่เจอให้ไป FlagZone (พิกัดเดิม)
        local flag = zones:FindFirstChild("FlagZone")
        return flag and (flag.CFrame * CFrame.new(4, -11.2, 0))
    end
    return nil
end

-- [[ 6. ระบบ Loop TP ]]
RunService.Stepped:Connect(function()
    if mode == "None" then return end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if root then
        local target = getTarget()
        if target then
            root.CFrame = target
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
    end
end)

-- [[ 7. ระบบปุ่มและการจัดการ Exit Logic ]]
local function updateUI()
    btnLock.Text = (mode == "Lock") and "LockPos: ON" or "LockPos: OFF"
    btnLock.BackgroundColor3 = (mode == "Lock") and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(80, 80, 80)
    
    btnFlag.Text = (mode == "Flag") and "FlagFarm: ON" or "FlagFarm: OFF"
    btnFlag.BackgroundColor3 = (mode == "Flag") and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(80, 80, 80)
    
    btnAuto.Text = (mode == "Auto") and "AutoFarm: ON" or "AutoFarm: OFF"
    btnAuto.BackgroundColor3 = (mode == "Auto") and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(80, 80, 80)
end

-- ฟังก์ชันสำหรับโผล่ขึ้นบนดิน
local function surfacePlayer()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        -- วาร์ปขึ้นมาที่ตำแหน่งปัจจุบัน แต่แกน Y = 5
        root.CFrame = CFrame.new(root.Position.X, EXIT_Y_HEIGHT, root.Position.Z)
    end
end

btnLock.MouseButton1Click:Connect(function()
    if mode == "Lock" then 
        mode = "None" 
        surfacePlayer() -- โผล่บนดินเมื่อปิด
    else
        mode = "Lock"
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            savedCFrame = player.Character.HumanoidRootPart.CFrame
        end
    end
    updateUI()
end)

btnFlag.MouseButton1Click:Connect(function()
    if mode == "Flag" then 
        mode = "None" 
        surfacePlayer() -- โผล่บนดินเมื่อปิด
    else
        mode = "Flag"
    end
    updateUI()
end)

btnAuto.MouseButton1Click:Connect(function()
    if mode == "Auto" then 
        mode = "None" 
        surfacePlayer() -- โผล่บนดินเมื่อปิด
    else
        mode = "Auto"
    end
    updateUI()
end)
