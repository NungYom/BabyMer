-- Roblox Godly Hunter V2 Pro: Manual & Auto Collect
-- Description: Q = Manual TP | P = Toggle Auto Collect (Detect, Collect, Claim)

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

local entitiesFolder = workspace:WaitForChild("EntitiesFolder")
local claimZone = workspace:WaitForChild("ClaimZone")

-- Settings
local autoCollectEnabled = false
local isProcessing = false -- ป้องกันการทำงานทับซ้อน
local excludedPositions = {
    Vector3.new(421.796173, 74.812767, 151.834137),
    Vector3.new(439.000092, 93.5329514, -2.00000381),
    Vector3.new(527.250061, 126.200401, -58.0051613)
}

-- ฟังก์ชันเช็คพิกัดยกเว้น
local function isExcluded(pos)
    for _, exPos in ipairs(excludedPositions) do
        if (pos - exPos).Magnitude < 7 then return true end
    end
    return false
end

-- ฟังก์ชันค้นหาเป้าหมาย Godly
local function findGodlyTarget()
    for _, entity in ipairs(entitiesFolder:GetChildren()) do
        local hrp = entity:FindFirstChild("HumanoidRootPart")
        if hrp then
            local billboard = hrp:FindFirstChild("EntityBillboardTemplate")
            local rarityLabel = billboard and billboard:FindFirstChild("TextLabels") and billboard.TextLabels:FindFirstChild("RarityLabel")
            
            if rarityLabel and rarityLabel:FindFirstChild("GodlyRarity") then
                if not isExcluded(hrp.Position) then
                    return entity
                end
            end
        end
    end
    return nil
end

-- ฟังก์ชันเก็บของ (Hold E)
local function collectItem(target)
    local proximityPrompt = target.HumanoidRootPart:FindFirstChildOfClass("ProximityPrompt")
    if proximityPrompt then
        -- TP ไปหาของ
        rootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
        task.wait(0.2)
        
        -- จำลองการกด E ค้างไว้ 0.5 วินาที
        proximityPrompt:InputHoldBegin()
        task.wait(0.5)
        proximityPrompt:InputHoldEnd()
        return true
    end
    return false
end

-- ฟังก์ชันหลักของระบบ Auto
task.spawn(function()
    while true do
        if autoCollectEnabled and not isProcessing then
            local target = findGodlyTarget()
            if target then
                isProcessing = true
                print("💎 พบ Godly! กำลังเริ่มเก็บ...")
                
                -- 1. วาร์ปไปเก็บ
                if collectItem(target) then
                    task.wait(0.5)
                    
                    -- 2. วาร์ปไปส่งที่ ClaimZone
                    print("🚚 กำลังนำไปส่งที่ ClaimZone")
                    rootPart.CFrame = claimZone.CFrame + Vector3.new(0, 3, 0)
                    task.wait(1.2) -- ยืนรอ 1 วินาทีตามเงื่อนไข
                end
                
                isProcessing = false
            end
        end
        task.wait(0.3) -- ตรวจจับทุก 0.3 วินาที
    end
end)

-- ควบคุมปุ่มกด
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    -- Q: Manual Teleport (วาร์ปไปดูเฉยๆ หรือเลือกเป้าหมาย)
    if input.KeyCode == Enum.KeyCode.Q then
        local target = findGodlyTarget()
        if target then
            rootPart.CFrame = target.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
            print("🚀 Manual TP to Godly")
        end
        
    -- P: Toggle Auto Collect
    elseif input.KeyCode == Enum.KeyCode.P then
        autoCollectEnabled = not autoCollectEnabled
        print(autoCollectEnabled and "🤖 [AUTO] ON" or "🤖 [AUTO] OFF")
    end
end)

print("---------------------------------------")
print("✅ Godly Hunter V2 Loaded!")
print("⌨️ Press 'Q' to Manual TP")
print("⌨️ Press 'P' to Toggle Auto Collect")
print("---------------------------------------")
