-- [[ SERVICES & VARIABLES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local fishRemote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("FishingService"):WaitForChild("RE"):WaitForChild("remote")

getgenv().AutoReel = false
getgenv().CastPos = nil
getgenv().TargetUUID = nil

-- [[ HOOK: ดักจับพิกัดแบบ 1 ชั้น (แก้บัค unpack) ]]
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if not checkcaller() and self == fishRemote and method == "FireServer" then
        local data = args[1] -- รับข้อมูลแบบ 1 ชั้นที่ถูก unpack มาแล้ว
        
        if type(data) == "table" then
            if data.kind == "requestCast" and type(data.targetPosition) == "table" then
                local pos = data.targetPosition
                if pos.X and pos.Y and pos.Z then
                    getgenv().CastPos = Vector3.new(pos.X, pos.Y, pos.Z)
                    getgenv().TargetUUID = nil -- รีเซ็ตเป้าหมาย
                    StatusText.Text = "Cast Pos Captured!"
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- [[ MAIN LOOP: หา Mesh CFrame แล้ว Spam ดึง ]]
task.spawn(function()
    while task.wait(0.05) do
        if getgenv().AutoReel and getgenv().CastPos then
            
            -- 1. หา Mesh ที่ CFrame ใกล้ทุ่นที่สุด
            if not getgenv().TargetUUID then
                local closestDist = 40
                local foundUUID = nil

                for _, obj in ipairs(Workspace:GetChildren()) do
                    -- หาชื่อ Model แม่ที่เป็น UUID
                    local extractedUUID = string.match(obj.Name, "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x")
                    
                    if extractedUUID then
                        -- เข้าถึง Mesh ย่อย
                        local mesh = obj:FindFirstChild("Mesh")
                        if mesh and mesh:IsA("BasePart") then
                            local meshPos = mesh.CFrame.Position
                            local dist = (meshPos - getgenv().CastPos).Magnitude
                            
                            if dist < closestDist then
                                closestDist = dist
                                foundUUID = extractedUUID
                            end
                        end
                    end
                end

                if foundUUID then
                    getgenv().TargetUUID = foundUUID
                    StatusText.Text = "Pulling: " .. string.sub(foundUUID, 1, 6) .. "!"
                end
            end

            -- 2. Spam Remote ดึงเบ็ด (ใช้ Table ชั้นเดียวตามรูปแบบ unpack)
            if getgenv().TargetUUID then
                -- ยิงแบบ Normal
                fishRemote:FireServer({
                    kind = "requestReel",
                    uuid = getgenv().TargetUUID
                })
                
                -- ยิงแบบ Critical
                fishRemote:FireServer({
                    kind = "requestCriticalReel",
                    uuid = getgenv().TargetUUID
                })
            end
            
        end
    end
end)

-- [[ UI TOGGLE ]]
ToggleBtn.MouseButton1Click:Connect(function()
    getgenv().AutoReel = not getgenv().AutoReel
    if getgenv().AutoReel then
        ToggleBtn.Text = "AUTO REEL: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    else
        ToggleBtn.Text = "AUTO REEL: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        getgenv().CastPos = nil
        getgenv().TargetUUID = nil
        StatusText.Text = "Waiting for Cast..."
    end
end)
