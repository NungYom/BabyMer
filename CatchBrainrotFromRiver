-- [[ 2. LOGIC: ดักจับ unpack(args) และหาระยะ CFrame ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local fishRemote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("FishingService"):WaitForChild("RE"):WaitForChild("remote")

getgenv().AutoReel = false
getgenv().CastPos = nil

-- Function สำหรับสลับสถานะ (ใช้ได้ทั้งคลิกและปุ่มกด)
local function ToggleFunction()
    getgenv().AutoReel = not getgenv().AutoReel
    if getgenv().AutoReel then
        ToggleBtn.Text = "AUTO REEL: ON [K]"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    else
        ToggleBtn.Text = "AUTO REEL: OFF [K]"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        getgenv().CastPos = nil
        StatusText.Text = "Waiting for Cast..."
    end
end

-- Hook พิกัด (ดัก unpack แบบปลอดภัย)
local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if not checkcaller() and self == fishRemote and method == "FireServer" then
        if args[1] and args[1].kind == "requestCast" and args[1].targetPosition then
            local p = args[1].targetPosition
            getgenv().CastPos = Vector3.new(p.X, p.Y, p.Z)
            StatusText.Text = "Cast Locked!"
        end
    end
    return old(self, ...)
end)

-- Main Loop: ค้นหา Mesh UUID
task.spawn(function()
    while task.wait(0.05) do
        if getgenv().AutoReel and getgenv().CastPos then
            for _, obj in ipairs(Workspace:GetChildren()) do
                local uuid = string.match(obj.Name, "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x")
                if uuid then
                    local mesh = obj:FindFirstChild("Mesh")
                    if mesh and mesh:IsA("BasePart") then
                        -- ตรวจระยะจาก CFrame Position
                        if (mesh.CFrame.Position - getgenv().CastPos).Magnitude < 30 then
                            StatusText.Text = "Reeling UUID..."
                            fishRemote:FireServer({kind = "requestReel", uuid = uuid})
                            fishRemote:FireServer({kind = "requestCriticalReel", uuid = uuid})
                        end
                    end
                end
            end
        end
    end
end)

-- [[ 3. INPUT CONTROL ]]
-- รองรับการคลิก (ลองหลาย Event)
ToggleBtn.MouseButton1Click:Connect(ToggleFunction)
ToggleBtn.Activated:Connect(ToggleFunction)

-- รองรับปุ่มกด Hotkey "K" สำหรับ PC
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.K then
        ToggleFunction()
    end
end)
