local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "FARM",
   LoadingTitle = "Loading Gemini Hub...",
   LoadingSubtitle = "Final Stable Version",
   ConfigurationSaving = { Enabled = false }
})

-- Global Variables
local _G = {
    AutoBolt = false,
    AutoMedal = false,
    YOffset = 4, 
    SafePoint = Vector3.new(142, 174, 50),
    IsHealing = false,
    LastTarget = nil,
    OutsideTimer = 0 -- ตัวนับเวลาสำหรับเช็คการอยู่นอก SafePoint
}

local Player = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")

-- ฟังก์ชันหา NPC ที่เลือดเยอะที่สุด
local function getStrongestNPC()
    local folder = workspace:FindFirstChild("PVEDogs")
    if not folder then return nil end
    local target = nil
    local maxHealth = -1
    for _, v in pairs(folder:GetChildren()) do
        local hum = v:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            if hum.Health > maxHealth then
                maxHealth = hum.Health
                target = v
            end
        end
    end
    return target
end

-- สร้าง Tabs
local Tab1 = Window:CreateTab("Bolt Farm", 4483362458)
local Tab2 = Window:CreateTab("Medal Farm", 4483362458)

-- [ AUTO BOLT ]
Tab1:CreateToggle({
   Name = "Auto Farm Bolts",
   CurrentValue = false,
   Flag = "BoltToggle",
   Callback = function(Value)
      _G.AutoBolt = Value
      if Value then
          task.spawn(function()
              while _G.AutoBolt do
                  pcall(function()
                      local folder = workspace:FindFirstChild("MainScene") and workspace.MainScene:FindFirstChild("1") and workspace.MainScene["1"]:FindFirstChild("FunctionFolder")
                      if folder then
                          for _, obj in pairs(folder:GetChildren()) do
                              if not _G.AutoBolt then break end
                              if string.find(obj.Name, "Bolt") then
                                  local char = Player.Character
                                  local root = char and char:FindFirstChild("HumanoidRootPart")
                                  local targetPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or obj
                                  
                                  if root and targetPart then
                                      root.CFrame = targetPart.CFrame
                                      task.wait(0.3)
                                  end
                              end
                          end
                      end
                  end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

-- [ AUTO MEDAL ]
Tab2:CreateToggle({
   Name = "Auto Farm Medal (PvE/PvP)",
   CurrentValue = false,
   Flag = "MedalToggle",
   Callback = function(Value)
      _G.AutoMedal = Value
      if Value then
          _G.OutsideTimer = tick() -- เริ่มจับเวลาครั้งแรก
          task.spawn(function()
              while _G.AutoMedal do
                  pcall(function()
                      local char = Player.Character
                      local root = char and char:FindFirstChild("HumanoidRootPart")
                      if not root then return end

                      local hp = Player:FindFirstChild("PlayerHP") and Player.PlayerHP.Value or 100
                      local maxHp = Player:FindFirstChild("PlayerTotalHP") and Player.PlayerTotalHP.Value or 100

                      -- ระบบเช็คเวลา: ถ้าอยู่นอก SafePoint นานเกิน 5 วินาที
                      local currentDist = (root.Position - _G.SafePoint).Magnitude
                      if currentDist > 5 then
                          if (tick() - _G.OutsideTimer) > 5 then
                              root.CFrame = CFrame.new(_G.SafePoint)
                              task.wait(1) -- พัก 1 วินาที
                              _G.OutsideTimer = tick() -- Reset เวลาใหม่
                              return -- กลับไปเริ่มลูปใหม่
                          end
                      else
                          _G.OutsideTimer = tick() -- ถ้ายังอยู่ที่ SafePoint ให้ Reset เวลาไว้ตลอด
                      end

                      -- 1. เช็คเลือด (Heal)
                      if hp < (maxHp * 0.6) or _G.IsHealing then
                          _G.IsHealing = true
                          root.CFrame = CFrame.new(_G.SafePoint)
                          if hp >= maxHp then _G.IsHealing = false end
                      else
                          -- 2. เช็คผู้เล่น (PvP Priority)
                          local atkRange = Player:FindFirstChild("PlayerAtkRange") and Player.PlayerAtkRange.Value or 50
                          local pvpTarget = nil
                          for _, p in pairs(game.Players:GetPlayers()) do
                              if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                  local pRoot = p.Character.HumanoidRootPart
                                  local dist = (Vector2.new(root.Position.X, root.Position.Z) - Vector2.new(pRoot.Position.X, pRoot.Position.Z)).Magnitude
                                  if dist <= atkRange then
                                      pvpTarget = p
                                      break
                                  end
                              end
                          end

                          if pvpTarget then
                              local remote = RS:FindFirstChild("Msg") and RS.Msg:FindFirstChild("RemoteEvent")
                              if remote then
                                  remote:FireServer("Player selects the target", {pvpTarget})
                              end
                              task.wait(0.1)
                          else
                              -- 3. ตี NPC (PvE)
                              local targetNPC = getStrongestNPC()
                              
                              if not targetNPC then
                                  root.CFrame = CFrame.new(_G.SafePoint)
                                  task.wait(0.5)
                              else
                                  -- เช็คว่าเป้าหมายเดิมตายไปหรือยัง (วาร์ปกลับพัก 1 วิ)
                                  if _G.LastTarget and _G.LastTarget ~= targetNPC then
                                      root.CFrame = CFrame.new(_G.SafePoint)
                                      task.wait(1)
                                      _G.OutsideTimer = tick() -- Reset เวลาเมื่อมีการพัก
                                  end
                                  
                                  _G.LastTarget = targetNPC
                                  
                                  if targetNPC:FindFirstChild("HumanoidRootPart") then
                                      root.CFrame = targetNPC.HumanoidRootPart.CFrame * CFrame.new(0, -_G.YOffset, 0)
                                      local remote = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("GuardianDogDamageEvent")
                                      if remote then
                                          remote:FireServer(targetNPC, 0)
                                      end
                                  end
                              end
                          end
                      end
                  end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

Tab2:CreateSlider({
   Name = "Y-Offset (Under NPC)",
   Range = {0, 50},
   Increment = 1,
   CurrentValue = 4,
   Callback = function(v) _G.YOffset = v end
})

