local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Medal & NPC Farm Pro",
   LoadingTitle = "Initializing Combat System...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = { Enabled = false }
})

-- ข้อมูลตัวแปรเซ็ตติ้ง
local _G = {
    MedalFarm = false,
    YOffset = 5,
    SafePoint = Vector3.new(0.956054688, 174, -27.058403),
    CurrentTarget = nil,
    IsHealing = false
}

-- ตัวแปรอ้างอิง Service และผู้เล่น
local lp = game:GetService("Players").LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local pveFolder = workspace:WaitForChild("PVEDogs")

-- ฟังก์ชันคำนวณระยะทางแบบ 2D (ตัดแกน Y)
local function getDistance2D(pos1, pos2)
    return (Vector2.new(pos1.X, pos1.Z) - Vector2.new(pos2.X, pos2.Z)).Magnitude
end

-- ฟังก์ชันหา NPC ที่เลือดเยอะที่สุด
local function getStrongestNPC()
    local maxHealth = -1
    local target = nil
    for _, npc in pairs(pveFolder:GetChildren()) do
        local hum = npc:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 and hum.Health > maxHealth then
            maxHealth = hum.Health
            target = npc
        end
    end
    return target
end

-- ฟังก์ชันหาผู้เล่นคนอื่นในระยะ AtkRange
local function getNearbyPlayer()
    local range = lp:FindFirstChild("PlayerAtkRange") and lp.PlayerAtkRange.Value or 50
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = getDistance2D(myRoot.Position, p.Character.HumanoidRootPart.Position)
            if dist <= range then
                return p
            end
        end
    end
    return nil
end

-- สร้าง UI
local Tab = Window:CreateTab("Medal Farm", 4483362458)

Tab:CreateToggle({
   Name = "Auto Medal Farm (PvE + PvP)",
   CurrentValue = false,
   Flag = "MedalToggle",
   Callback = function(Value)
      _G.MedalFarm = Value
      if Value then
          task.spawn(function()
              while _G.MedalFarm do
                  local char = lp.Character
                  local root = char and char:FindFirstChild("HumanoidRootPart")
                  local hpValue = lp:FindFirstChild("PlayerHP") and lp.PlayerHP.Value or 100
                  local maxHpValue = lp:FindFirstChild("PlayerTotalHP") and lp.PlayerTotalHP.Value or 100
                  
                  -- 1. เช็คสถานะเลือด (Safety First)
                  if hpValue < (maxHpValue * 0.6) or _G.IsHealing then
                      _G.IsHealing = true
                      root.CFrame = CFrame.new(_G.SafePoint)
                      if hpValue >= maxHpValue then _G.IsHealing = false end
                      task.wait(0.5)
                  
                  else
                      -- 2. เช็คผู้เล่นใกล้ๆ (PvP Priority)
                      local pvpTarget = getNearbyPlayer()
                      if pvpTarget then
                          local args = { "Player selects the target", { pvpTarget } }
                          rs:WaitForChild("Msg"):WaitForChild("RemoteEvent"):FireServer(unpack(args))
                          task.wait(0.1)
                      
                      else
                          -- 3. ฟาร์ม NPC (PvE Mode)
                          if not _G.CurrentTarget or not _G.CurrentTarget:Parent or (_G.CurrentTarget:FindFirstChildOfClass("Humanoid") and _G.CurrentTarget:FindFirstChildOfClass("Humanoid").Health <= 0) then
                              _G.CurrentTarget = getStrongestNPC()
                          end

                          if _G.CurrentTarget then
                              local targetRoot = _G.CurrentTarget:FindFirstChild("HumanoidRootPart")
                              if targetRoot then
                                  -- Teleport ไปใต้ตัวศัตรู
                                  root.CFrame = targetRoot.CFrame * CFrame.new(0, -_G.YOffset, 0)
                                  task.wait(1) -- รอ 1 วิตามเงื่อนไขที่กำหนด
                                  
                                  -- ส่งคำสั่งตี
                                  local args = { _G.CurrentTarget, 0 }
                                  rs:WaitForChild("Remotes"):WaitForChild("GuardianDogDamageEvent"):FireServer(unpack(args))
                              end
                          end
                          task.wait(0.1)
                      end
                  end
                  task.wait(0.05)
              end
          end)
      end
   end,
})

Tab:CreateSlider({
   Name = "TP Offset (Under NPC)",
   Range = {0, 50},
   Increment = 1,
   Suffix = "Studs",
   CurrentValue = 5,
   Flag = "YOffsetSlider",
   Callback = function(Value)
      _G.YOffset = Value
   end,
})
