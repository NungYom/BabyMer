-- MAIN LOOP
--==================================================
task.spawn(function()
    while true do
        local weapon = getWeapon()
        if not currentTarget or not currentTarget.Parent or not currentTarget:FindFirstChild("Model") then
            currentTarget = findTargetLogic()
        end
        if currentTarget and weapon then
            local root = currentTarget.Model:FindFirstChild("Root")
            if root then
                FireRE:FireServer("Hit", {fishInstance = currentTarget, HitPos = root.Position, toolInstance = weapon})
                if autoSkill or huntDragon then task.spawn(castSkillLoop) end
            end
        elseif autoSkill then
            task.spawn(castSkillLoop)
        end
        task.wait(0.2)
    end
end)

