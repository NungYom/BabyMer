--==================================================
-- CORE LOGIC
--==================================================

local function getWeapon()
    local weapon = character:FindFirstChildOfClass("Tool")
    if not weapon or not (weapon.Name:match("^Gun") or weapon.Name:match("^Harpoon")) then
        for _, v in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if v.Name:match("^Gun") or v.Name:match("^Harpoon") then return v end
        end
    end
    return weapon
end

local function tpToPoint(pointName)
    local worldBoss = workspace:FindFirstChild("WorldBoss")
    if worldBoss then
        local targetPoint = worldBoss:FindFirstChild(pointName)
        if targetPoint then
            HRP.CFrame = (targetPoint:IsA("BasePart") and targetPoint.CFrame or targetPoint.PrimaryPart.CFrame) * CFrame.new(0, 5, 0)
        end
    end
end

local function findTargetLogic()
    if huntDragon then
        local worldBoss = workspace:FindFirstChild("WorldBoss")
        if worldBoss then
            for _, point in ipairs(worldBoss:GetChildren()) do
                local boss = point:FindFirstChild("Boss07")
                if boss and boss:FindFirstChild("Model") and boss.Model:FindFirstChild("Root") then return boss end
            end
        end
    elseif autoAttack then
        local nearest, dist = nil, math.huge
        local worldSea = workspace:FindFirstChild("WorldSea")
        if worldSea then
            for _, sea in ipairs(worldSea:GetChildren()) do
                for _, fish in ipairs(sea:GetChildren()) do
                    local root = fish:FindFirstChild("Model") and fish.Model:FindFirstChild("Root")
                    if root then
                        local d = (HRP.Position - root.Position).Magnitude
                        if d < dist then dist = d nearest = fish end
                    end
                end
            end
        end
        return nearest
    end
    return nil
end

local function castSkillLoop()
    if skillBusy then return end
    skillBusy = true
    for i=1, 14 do
        if not (autoSkill or huntDragon) then break end
        FishRE:FireServer("Skill", {ID = string.format("Skill%02d", i)})
        task.wait(0.15)
    end
    skillBusy = false
end

