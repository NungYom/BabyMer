local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Plot Farm + Unit & Bee Collector",
   LoadingTitle = "System Booting...",
   LoadingSubtitle = "Gemini AI Advanced V2",
   ConfigurationSaving = { Enabled = false }
})

local _G = {
    AutoTP = false,
    AutoE = false,
    UnitTarget = {}, 
    CollectBee = false, -- ปุ่มเปิดปิดว่าจะเก็บผึ้งไหม
    IsCollectingUnit = false 
}

local vim = game:GetService("VirtualInputManager")
local targetUnits = {"Blacksmith", "Knight", "Fisherman", "BeeKeeper", "Ghoul King", "Cappuccino Assassino", "Talale Talala"}

-- ฟังก์ชันหา Plot
local function GetPlayerPlot()
    local playerName = game.Players.LocalPlayer.Name
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        local ownerObj = plot:FindFirstChild("Owner")
        if ownerObj and tostring(ownerObj.Value) == playerName then
            return plot
        end
    end
    return nil
end

local Tab = Window:CreateTab("Control Panel", 4483362458)

-- --- ส่วนที่ 3: ระบบตรวจจับ Unit & Bee (NEW!) ---
local SectionUnit = Tab:CreateSection("Special Unit & Bee")

Tab:CreateToggle({
   Name = "Auto Collect Bee (Follow + Hold E)",
   CurrentValue = false,
   Flag = "BeeToggle", 
   Callback = function(Value)
      _G.CollectBee = Value
   end,
})

Tab:CreateDropdown({
   Name = "Select Other Units",
   Options = targetUnits,
   CurrentOption = {},
   MultipleOptions = true,
   Flag = "SelectedUnits",
   Callback = function(Options)
      _G.UnitTarget = Options
   end,
})

-- ลูปหลักสำหรับตรวจสอบ Unit พิเศษ และ ผึ้ง
task.spawn(function()
    while true do
        task.wait(0.1) -- เช็คถี่ขึ้นเพื่อให้ทันผึ้ง
        if _G.IsCollectingUnit then continue end

        local playerChar = game.Players.LocalPlayer.Character
        if not playerChar or not playerChar:FindFirstChild("HumanoidRootPart") then continue end

        -- 1. ตรวจสอบ "ผึ้ง" (Bee) ก่อนเป็นอันดับแรก
        local foundBee = workspace:FindFirstChild("Bee")
        if _G.CollectBee and foundBee then
            local beeHRP = foundBee:FindFirstChild("HumanoidRootPart")
            if beeHRP then
                _G.IsCollectingUnit = true
                local oldPos = playerChar:GetPrimaryPartCFrame()
                
                -- ลูปวาร์ปตามผึ้งอย่างต่อเนื่องเป็นเวลา 1 วินาทีก่อนเริ่มเก็บ
                local startTime = tick()
                while tick() - startTime < 1 do
                    playerChar:SetPrimaryPartCFrame(beeHRP.CFrame * CFrame.new(0, 0, -2))
                    task.wait()
                end

                -- เริ่มกด E ค้าง 1.5 วินาที พร้อมวาร์ปตามไปด้วย (Sticky TP)
                vim:SendKeyEvent(true, Enum.KeyCode.E, false, game) -- กด E ลง
                
                local holdStartTime = tick()
                while tick() - holdStartTime < 1.5 do
                    if beeHRP.Parent then -- ถ้าผึ้งยังอยู่
                        playerChar:SetPrimaryPartCFrame(beeHRP.CFrame * CFrame.new(0, 0, -2))
                    end
                    task.wait()
                end
                
                vim:SendKeyEvent(false, Enum.KeyCode.E, false, game) -- ปล่อย E
                
                task.wait(0.5)
                playerChar:SetPrimaryPartCFrame(oldPos)
                _G.IsCollectingUnit = false
                Rayfield:Notify({Title = "Bee Caught!", Content = "เก็บผึ้งเรียบร้อยแล้ว", Duration = 3})
            end
            
        -- 2. ตรวจสอบ Unit อื่นๆ ใน List
        else
            for _, unitName in pairs(_G.UnitTarget) do
                local foundUnit = workspace:FindFirstChild(unitName)
                if foundUnit then
                    local hrp = foundUnit:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        _G.IsCollectingUnit = true
                        local oldPos = playerChar:GetPrimaryPartCFrame()
                        
                        playerChar:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(0, 0, -3))
                        task.wait(1)
                        
                        for i = 1, 3 do
                            vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                            task.wait(0.05)
                            vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                            task.wait(0.1)
                        end
                        
                        task.wait(0.5)
                        playerChar:SetPrimaryPartCFrame(oldPos)
                        _G.IsCollectingUnit = false
                        break
                    end
                end
            end
        end
    end
end)

-- --- ส่วนของ Farm Plot (เหมือนเดิม) ---
local SectionFarm = Tab:CreateSection("Plot Farming")
Tab:CreateToggle({
   Name = "Auto TP to Buildings",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoTP = Value
      if Value then
          task.spawn(function()
              while _G.AutoTP do
                  if not _G.IsCollectingUnit then
                      local myPlot = GetPlayerPlot()
                      if myPlot and myPlot:FindFirstChild("Building") then
                          for _, item in pairs(myPlot.Building:GetChildren()) do
                              if not _G.AutoTP or _G.IsCollectingUnit then break end
                              local mainPart = item:FindFirstChild("MainPart")
                              if mainPart then
                                  game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(mainPart.CFrame)
                                  task.wait(0.3)
                              end
                          end
                      end
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

Tab:CreateToggle({
   Name = "Auto Spam E",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoE = Value
      if Value then
          task.spawn(function()
              while _G.AutoE do
                  if not _G.IsCollectingUnit then
                      vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                      task.wait(0.05)
                      vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                  end
                  task.wait(0.2)
              end
          end)
      end
   end,
})
