local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Plot Farm: Split System",
   LoadingTitle = "Loading System...",
   LoadingSubtitle = "By Gemini AI",
   ConfigurationSaving = { Enabled = false }
})

local _G = {
    AutoTP = false,
    AutoE = false
}
local vim = game:GetService("VirtualInputManager")

-- ฟังก์ชันหา Plot ของผู้เล่น
local function GetPlayerPlot()
    local playerName = game.Players.LocalPlayer.Name
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        local ownerObj = plot:FindFirstChild("Owner")
        if ownerObj and tostring(ownerObj.Value) == playerName then
            return plot
        end
    end
    return nil
end

local Tab = Window:CreateTab("Control Panel", 4483362458)

-- --- ส่วนที่ 1: ระบบ Teleport ---
Tab:CreateToggle({
   Name = "1. Auto TP to Buildings",
   CurrentValue = false,
   Flag = "TPToggle", 
   Callback = function(Value)
      _G.AutoTP = Value
      if Value then
          task.spawn(function()
              while _G.AutoTP do
                  local myPlot = GetPlayerPlot()
                  if myPlot and myPlot:FindFirstChild("Building") then
                      local buildings = myPlot.Building:GetChildren()
                      for _, item in pairs(buildings) do
                          if not _G.AutoTP then break end
                          
                          local mainPart = item:FindFirstChild("MainPart")
                          if mainPart and mainPart:IsA("BasePart") then
                              -- วาร์ปไปที่จุด
                              game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(mainPart.CFrame)
                              -- รอ 0.3 วินาทีก่อนไปอันถัดไปตามโจทย์
                              task.wait(0.3)
                          end
                      end
                  else
                      task.wait(1) -- ถ้าหา Plot ไม่เจอให้รอแป๊บนึง
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

-- --- ส่วนที่ 2: ระบบรัวปุ่ม E ---
Tab:CreateToggle({
   Name = "2. Auto Spam E",
   CurrentValue = false,
   Flag = "EToggle", 
   Callback = function(Value)
      _G.AutoE = Value
      if Value then
          task.spawn(function()
              while _G.AutoE do
                  -- กดปุ่ม E
                  vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                  task.wait(0.05) -- หน่วงเวลาตอนกดลงเล็กน้อยให้เกมรับรู้
                  vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                  
                  -- เว้นระยะรัว 0.2 วินาทีตามโจทย์
                  task.wait(0.2)
              end
          end)
      end
   end,
})

Rayfield:Notify({
    Title = "System Ready",
    Content = "แยกปุ่ม TP และปุ่มรัว E เรียบร้อยแล้ว!",
    Duration = 5
})
