local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Plot God Mode: Priority System",
   LoadingTitle = "System Booting...",
   LoadingSubtitle = "Gemini AI Advanced V3",
   ConfigurationSaving = { Enabled = false }
})

local _G = {
    AutoTP = false,
    AutoE = false,
    UnitTarget = {}, 
    CollectBee = false,
    IsBusy = false -- ตัวล็อคสถานะ Priority
}

local vim = game:GetService("VirtualInputManager")
local player = game.Players.LocalPlayer
local targetUnits = {"Blacksmith", "Knight", "Fisherman", "BeeKeeper", "Ghoul King", "Cappuccino Assassino", "Talale Talala"}

-- ฟังก์ชันหา Plot ของตัวเอง
local function GetMyPlot()
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner and tostring(owner.Value) == player.Name then
            return plot
        end
    end
    return nil
end

-- ฟังก์ชันกด E แบบย้ำๆ
local function SpamE(amount, interval)
    for i = 1, amount do
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(interval)
    end
end

local Tab = Window:CreateTab("Main Settings", 4483362458)

-- UI สำหรับตั้งค่า
Tab:CreateToggle({Name = "Auto Collect Bee", CurrentValue = false, Callback = function(V) _G.CollectBee = V end})
Tab:CreateDropdown({
   Name = "Target Units",
   Options = targetUnits,
   MultipleOptions = true,
   Callback = function(Options) _G.UnitTarget = Options end,
})

-- --- Loop พิเศษ: หน่วยล่า Unit และผึ้ง ---
task.spawn(function()
    while true do
        task.wait(0.1)
        local myPlot = GetMyPlot()
        if not myPlot then continue end
        local myHitbox = myPlot:FindFirstChild("DeliveryHitbox")
        
        -- 1. เช็ค Special Units (Priority 1)
        for _, unitName in pairs(_G.UnitTarget) do
            local unit = workspace:FindFirstChild(unitName)
            if unit and unit:FindFirstChild("HumanoidRootPart") then
                local unitHRP = unit.HumanoidRootPart
                
                -- ตรวจสอบว่า Unit อยู่ใกล้ Hitbox ของคนอื่นหรือไม่ (กันโดนแย่ง)
                local isGoingToOthers = false
                for _, otherPlot in pairs(workspace.Plots:GetChildren()) do
                    if otherPlot ~= myPlot then
                        local otherHitbox = otherPlot:FindFirstChild("DeliveryHitbox")
                        if otherHitbox and (unitHRP.Position - otherHitbox.Position).Magnitude < 15 then
                            isGoingToOthers = true
                            break
                        end
                    end
                end

                -- ถ้ามันกำลังจะโดนแย่ง หรือเรายังไม่ได้กดรับมันเลย
                if isGoingToOthers or not unit:FindFirstChild("TargetedByMe") then
                    _G.IsBusy = true
                    local oldPos = player.Character:GetPrimaryPartCFrame()
                    
                    -- สร้าง Tag หลอกๆ ไว้เช็คว่าเรากดไปแล้ว
                    if not unit:FindFirstChild("TargetedByMe") then
                        local tag = Instance.new("BoolValue", unit)
                        tag.Name = "TargetedByMe"
                    end

                    -- TP ไปกด 5 ครั้ง
                    player.Character:SetPrimaryPartCFrame(unitHRP.CFrame * CFrame.new(0, 0, -3))
                    task.wait(0.2)
                    SpamE(5, 0.1)
                    
                    task.wait(0.3)
                    player.Character:SetPrimaryPartCFrame(oldPos)
                    _G.IsBusy = false
                end
            end
        end

        -- 2. เช็ค Bee (Priority 2)
        local bee = workspace:FindFirstChild("Bee")
        if _G.CollectBee and bee and bee:FindFirstChild("HumanoidRootPart") and not _G.IsBusy then
            local beeHRP = bee.HumanoidRootPart
            _G.IsBusy = true
            local oldPos = player.Character:GetPrimaryPartCFrame()
            
            -- วาร์ปตามและกด E ค้าง
            vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            local start = tick()
            while tick() - start < 1.5 and bee.Parent do
                player.Character:SetPrimaryPartCFrame(beeHRP.CFrame * CFrame.new(0, 0, -2))
                task.wait()
            end
            vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            
            task.wait(0.3)
            player.Character:SetPrimaryPartCFrame(oldPos)
            _G.IsBusy = false
        end
    end
end)

-- --- Loop รอง: เก็บผลผลิต Building ---
local SectionFarm = Tab:CreateSection("Plot Farming")
Tab:CreateToggle({
   Name = "Auto TP Building Items",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoTP = Value
      if Value then
          task.spawn(function()
              while _G.AutoTP do
                  if not _G.IsBusy then
                      local myPlot = GetMyPlot()
                      if myPlot and myPlot:FindFirstChild("Building") then
                          for _, building in pairs(myPlot.Building:GetChildren()) do
                              if not _G.AutoTP or _G.IsBusy then break end
                              local mainPart = building:FindFirstChild("MainPart")
                              if mainPart then
                                  player.Character:SetPrimaryPartCFrame(mainPart.CFrame)
                                  task.wait(0.3)
                              end
                          end
                      end
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

Tab:CreateToggle({
   Name = "Auto Spam E (Farm)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoE = Value
      if Value then
          task.spawn(function()
              while _G.AutoE do
                  if not _G.IsBusy then
                      vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                      task.wait(0.05)
                      vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                  end
                  task.wait(0.2)
              end
          end)
      end
   end,
})
