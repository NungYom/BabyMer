local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Plot Auto Collector",
   LoadingTitle = "Starting Script...",
   LoadingSubtitle = "Gemini AI Custom",
   ConfigurationSaving = { Enabled = false }
})

local _G = { AutoCollect = false }
local vim = game:GetService("VirtualInputManager")

-- ฟังชั่นตรวจสอบ Plot ของผู้เล่นแบบ Real-time
local function GetPlayerPlot()
    local playerName = game.Players.LocalPlayer.Name
    -- ตรวจสอบใน workspace.Plots ทั้งหมด (1-6 ตามโครงสร้างเกม)
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        local ownerObj = plot:FindFirstChild("Owner")
        if ownerObj and tostring(ownerObj.Value) == playerName then
            return plot
        end
    end
    return nil
end

local Tab = Window:CreateTab("Auto Farm", 4483362458)

Tab:CreateToggle({
   Name = "Start Auto Collect",
   CurrentValue = false,
   Flag = "AutoFarm", 
   Callback = function(Value)
      _G.AutoCollect = Value
      
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  local myPlot = GetPlayerPlot()
                  
                  if myPlot and myPlot:FindFirstChild("Building") then
                      local buildings = myPlot.Building:GetChildren()
                      
                      for _, item in pairs(buildings) do
                          if not _G.AutoCollect then break end
                          
                          local mainPart = item:FindFirstChild("MainPart")
                          if mainPart and mainPart:IsA("BasePart") then
                              -- 1. TP ไปยังจุดเก็บ
                              game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(mainPart.CFrame)
                              
                              -- 2. รอ 0.3 วินาที (ตามที่คุณต้องการ)
                              task.wait(0.3)
                              
                              -- 3. จำลองการกดปุ่ม E
                              vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                              task.wait(0.05)
                              vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                              
                              -- 4. รอ 0.2 วินาที ก่อนจะไปอันถัดไป
                              task.wait(0.2)
                          end
                      end
                  else
                      -- ถ้าหา Plot ไม่เจอ ให้รอแป๊บนึงแล้วเช็คใหม่
                      task.wait(1)
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

Rayfield:Notify({
    Title = "Script Ready",
    Content = "สคริปต์พร้อมทำงาน! ระบบจะหา Plot ของคุณอัตโนมัติ",
    Duration = 5
})
