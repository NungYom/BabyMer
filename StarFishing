local function getBackpackObj()
    local char = lp.Character
    return (char and char:FindFirstChild("Backpack")) or lp.Backpack:FindFirstChild("Backpack")
end

local function isTarget(itemName)
    local n = string.lower(tostring(itemName))
    for _, cat in ipairs(FilterSettings) do
        if cat.enabled then
            for _, t in ipairs(cat.items) do if string.find(n, string.lower(t)) then return true end end
        end
    end
    return false
end

local function pressSlot1()
    vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
    task.wait(0.05)
    vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
end

local function performCast()
    -- ป้องกันการเหวี่ยงเบ็ดถ้ากำลัง TP หรือ กำลังขายของ
    if not active or isTeleporting or isSelling then return end
    
    local char = lp.Character
    if not char then return end
    local rod = char:FindFirstChild("Rod") or lp.Backpack:FindFirstChild("Rod")
    if rod then
        if rod.Parent == lp.Backpack then pressSlot1() task.wait(0.3) end
        local attach = rod:FindFirstChild("Attachment", true)
        local root = char:FindFirstChild("HumanoidRootPart")
        if attach and root then
            ReplicatedStorage.Events.Global.Cast:FireServer(char.Humanoid, root.Position, root.CFrame.LookVector, attach)
        end
    end
end

-- [[ SYSTEM: DUAL EYE + POOLED FLOAT ]]
task.spawn(function()
    while true do
        -- จะย้ายที่ได้ต่อเมื่อ "ไม่ได้กำลังขายของ" เท่านั้น
        if currentEye ~= "None" and not isSelling and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local minute = os.date("!*t").min
            local root = lp.Character.HumanoidRootPart
            floatObject.Parent = root
            floatObject.MaxForce = Vector3.new(1e6, 1e6, 1e6)

            local targetPos, lookAtPos
            if (minute >= 0 and minute < 15) or (minute >= 30 and minute < 45) then
                targetPos = Vector3.new(206, 35, -302)
                lookAtPos = Vector3.new(241.794388, 35, -312.383881)
            else
                if currentEye == "Negative" then
                    targetPos = Vector3.new(370, 49, 137)
                    lookAtPos = Vector3.new(398.594147, 49, 144.852356)
                else
                    targetPos = Vector3.new(-49, 5, 30266)
                    lookAtPos = Vector3.new(-48.8923225, 5, 30287.5039)
                end
            end

            if (root.Position - targetPos).Magnitude > 5 then
                isTeleporting = true
                -- รอเบ็ดเก็บก่อน TP
                repeat task.wait(0.5) until not workspace:FindFirstChild("Bobber") or not active
                root.CFrame = CFrame.lookAt(targetPos, lookAtPos)
                task.wait(1.5) -- เพิ่มเวลาให้โหลด Map นิดนึง
                isTeleporting = false
                if active then performCast() end
            end
        else
            floatObject.MaxForce = Vector3.new(0, 0, 0)
        end
        task.wait(1)
    end
end)

-- [[ EVENT: RECEIVE ITEMS ]]
ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(success, p1, p2, items)
    if not (active and success and items) then return end
    
    task.spawn(function()
        local hasTarget = false
        for _, item in pairs(items) do
            if isTarget(item.name) then hasTarget = true break end
        end

        local bpObj = getBackpackObj()

        if hasTarget and bpObj then
            -- 1. เก็บของเป้าหมายให้ครบก่อน
            local capacityLimit = tonumber(lp.PlayerGui.FishingProGUI.MainFrame.CapInput.Text) or 1
            local startNewItems = bpObj:GetAttribute("NewItems") or 0
            local goal = startNewItems + capacityLimit
            
            local timeout = 0
            while active and timeout < 150 do
                local currentVal = bpObj:GetAttribute("NewItems") or 0
                if currentVal >= goal then break end
                for _, item in pairs(items) do
                    if item.id then ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(item.id) end
                end
                task.wait(0.1)
                timeout = timeout + 1
            end

            -- 2. ดึงเบ็ดขึ้น
            if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(lp.Character.Humanoid)
            end
            task.wait(0.4)

            -- 3. เข้าสู่ช่วงขายของ (ล็อคไม่ให้ TP แทรก)
            isSelling = true
            for _, item in ipairs(items) do
                if not isTarget(item.name) then
                    ReplicatedStorage.Events.Global.ClientEquipStar:FireServer(item)
                    task.wait(0.15)
                    local sellArgs = {{id = "sell-current", text = "Sell this star.", npc = "Star Merchant"}}
                    ReplicatedStorage.Dialogue.Events.Global.ClientChoosesDialogueOption:FireServer(unpack(sellArgs))
                    task.wait(0.1)
                end
            end
            isSelling = false -- ปลดล็อคเมื่อขายจบ
            task.wait(0.2)
        else
            -- กรณีไม่เจอของเป้าหมาย (Reset Gear ปกติ)
            pressSlot1() task.wait(0.2)
            pressSlot1() task.wait(0.3)
        end

        -- ตรวจสอบอีกครั้งว่าย้ายที่เสร็จหรือยังก่อนเหวี่ยงใหม่
        if not isTeleporting then performCast() end
    end)
end)

