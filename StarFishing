-- [[ FAST AUTO-FISH v6.1: RELIABLE TURBO ]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer

local active = false

local function getBackpackObj()
    local char = lp.Character
    return (char and char:FindFirstChild("Backpack")) or lp.Backpack:FindFirstChild("Backpack")
end

local function castRod()
    if not active then return end
    local char = lp.Character
    local rod = char and (char:FindFirstChild("Rod") or lp.Backpack:FindFirstChild("Rod"))
    
    if rod then
        if rod.Parent == lp.Backpack then
            char.Humanoid:EquipTool(rod)
            task.wait(0.1)
        end
        local attach = rod:FindFirstChild("Attachment", true)
        local root = char:FindFirstChild("HumanoidRootPart")
        if attach and root then
            ReplicatedStorage.Events.Global.Cast:FireServer(char.Humanoid, root.Position, root.CFrame.LookVector, attach)
        end
    end
end

ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(success, p1, p2, items)
    if active and success and items then
        local bpObj = getBackpackObj()
        if not bpObj then return end

        -- ใช้ Attribute 'Capacity' จากตัวกระเป๋า (ของคุณคือ 4)
        local capacityLimit = bpObj:GetAttribute("Capacity") or #items 
        local startNewItems = bpObj:GetAttribute("NewItems") or 0
        local goal = startNewItems + capacityLimit
        
        warn("⚡ [RELIABLE TURBO]: เป้าหมายคือ " .. goal .. " (รอครบ " .. capacityLimit .. " ชิ้น)")

        -- ใช้ Task.spawn เพื่อไม่ให้ขัดจังหวะการรับ Event อื่นๆ
        task.spawn(function()
            local timeout = 0
            -- วนลูปจนกว่าค่า NewItems จะขยับขึ้นมาจนครบเป้าหมายจริงๆ
            while active and timeout < 150 do -- ขยายเวลา Timeout เผื่อ Server หน่วง
                local currentVal = bpObj:GetAttribute("NewItems") or 0
                
                -- เงื่อนไขสำคัญ: ต้องเท่ากับหรือมากกว่าเป้าหมายถึงจะหยุด
                if currentVal >= goal then
                    warn("✨ [DONE]: ครบแล้ว! (NewItems: " .. currentVal .. ")")
                    break 
                end

                -- ส่ง Confirm ทุกตัวในรายการ
                for _, item in pairs(items) do
                    if item.id then 
                        ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(item.id)
                    end
                end
                
                -- รอจังหวะที่สั้นพอดีเพื่อให้ Server อัปเดตค่าทัน (0.05 - 0.1 วิ)
                task.wait(0.1) 
                timeout = timeout + 1
            end
            
            -- เมื่อตรวจสอบแล้วว่าเลขครบ 4 ตัว (หรือตาม Capacity) ค่อยดึงเบ็ดและเหวี่ยงใหม่
            local char = lp.Character
            if char and char:FindFirstChild("Humanoid") then
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(char.Humanoid)
            end
            
            task.wait(0.3) -- พักนิดนึงก่อนเหวี่ยงใหม่เพื่อความเสถียร
            castRod()
        end)
    end
end)

-- UI Setup
local screenGui = Instance.new("ScreenGui", lp.PlayerGui)
local mainButton = Instance.new("TextButton", screenGui)
mainButton.Size = UDim2.new(0, 200, 0, 60)
mainButton.Position = UDim2.new(0.5, -100, 0.1, 0)
mainButton.Text = "AUTO FISH: OFF"
mainButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
mainButton.TextColor3 = Color3.new(1, 1, 1)
mainButton.Font = Enum.Font.SourceSansBold
mainButton.TextSize = 22

mainButton.MouseButton1Click:Connect(function()
    active = not active
    mainButton.Text = active and "AUTO FISH: ON" or "AUTO FISH: OFF"
    mainButton.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    if active then castRod() end
end)
