for _, data in ipairs(FilterSettings) do
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1, -10, 0, 35); btn.Text = data.name .. ": ON"; btn.BackgroundColor3 = data.color; btn.TextColor3 = Color3.new(0,0,0)
