-- [[ FAST AUTO-FISH v6.3: PERSISTENT GOAL TURBO ]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local lp = Players.LocalPlayer

local active = false
local nextGoal = 0 -- ตัวแปรเป้าหมายรวมที่จะสะสมไปเรื่อยๆ

-- ฟังก์ชันดึง Object ของกระเป๋า
local function getBackpackObj()
    local char = lp.Character
    return (char and char:FindFirstChild("Backpack")) or lp.Backpack:FindFirstChild("Backpack")
end

-- UI Setup
local screenGui = Instance.new("ScreenGui", lp.PlayerGui)
screenGui.Name = "AutoFishV6.3"

local mainButton = Instance.new("TextButton", screenGui)
mainButton.Size = UDim2.new(0, 200, 0, 50)
mainButton.Position = UDim2.new(0.5, -100, 0.1, 0)
mainButton.Text = "AUTO FISH: OFF"
mainButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
mainButton.TextColor3 = Color3.new(1, 1, 1)
mainButton.Font = Enum.Font.SourceSansBold
mainButton.TextSize = 20

local inputField = Instance.new("TextBox", screenGui)
inputField.Size = UDim2.new(0, 200, 0, 40)
inputField.Position = UDim2.new(0.5, -100, 0.1, 55)
inputField.PlaceholderText = "Step Capacity (เช่น 30)"
inputField.Text = "30" 
inputField.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
inputField.TextColor3 = Color3.fromRGB(255, 255, 255)
inputField.Font = Enum.Font.SourceSans
inputField.TextSize = 18

local statusLabel = Instance.new("TextLabel", screenGui)
statusLabel.Size = UDim2.new(0, 200, 0, 25)
statusLabel.Position = UDim2.new(0.5, -100, 0.1, 100)
statusLabel.Text = "Waiting for Start..."
statusLabel.BackgroundColor3 = Color3.new(0,0,0)
statusLabel.BackgroundTransparency = 0.5
statusLabel.TextColor3 = Color3.new(1, 1, 1)
statusLabel.TextSize = 16

-- ฟังก์ชันการเหวี่ยงเบ็ด
local function castRod()
    if not active then return end
    local char = lp.Character
    local rod = char and (char:FindFirstChild("Rod") or lp.Backpack:FindFirstChild("Rod"))
    
    if rod then
        if rod.Parent == lp.Backpack then
            char.Humanoid:EquipTool(rod)
            task.wait(0.1)
        end
        local attach = rod:FindFirstChild("Attachment", true)
        local root = char:FindFirstChild("HumanoidRootPart")
        if attach and root then
            ReplicatedStorage.Events.Global.Cast:FireServer(char.Humanoid, root.Position, root.CFrame.LookVector, attach)
        end
    end
end

-- ระบบจัดการเมื่อได้รับไอเทม
ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(success, p1, p2, items)
    if active and success and items then
        local bpObj = getBackpackObj()
        if not bpObj then return end

        task.spawn(function()
            local timeout = 0
            while active and timeout < 200 do
                local currentVal = bpObj:GetAttribute("NewItems") or 0
                
                -- ตรวจสอบว่าถึงเป้าหมายสะสม (nextGoal) หรือยัง
                if currentVal >= nextGoal then
                    -- เมื่อถึงเป้าหมายแล้ว ให้ตั้งเป้าหมายถัดไปทันที (เป้าหมายเดิม + ค่าที่พิมพ์)
                    local step = tonumber(inputField.Text) or 1
                    nextGoal = currentVal + step
                    
                    statusLabel.Text = "DONE! Next Target: " .. nextGoal
                    warn("✨ [MATCHED]: ถึง " .. currentVal .. " แล้ว! รอบต่อไปคือ " .. nextGoal)
                    break 
                end

                -- แสดงสถานะ Real-time บนจอ
                statusLabel.Text = "Progress: " .. currentVal .. " / " .. nextGoal

                -- กดยืนยันไอเทม
                for _, item in pairs(items) do
                    if item.id then 
                        ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(item.id)
                    end
                end
                
                task.wait(0.05) 
                timeout = timeout + 1
            end
            
            -- ดึงเบ็ดกลับและเหวี่ยงใหม่
            local char = lp.Character
            if char and char:FindFirstChild("Humanoid") then
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(char.Humanoid)
            end
            
            task.wait(0.5) -- เพิ่มดีเลย์นิดหน่อยเพื่อให้ Server เคลียร์สถานะ
            castRod()
        end)
    end
end)

-- ปุ่มกด เปิด/ปิด
mainButton.MouseButton1Click:Connect(function()
    active = not active
    mainButton.Text = active and "AUTO FISH: ON" or "AUTO FISH: OFF"
    mainButton.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    
    if active then 
        -- เมื่อเริ่มทำงาน ให้คำนวณค่าเริ่มต้นทันที
        local bpObj = getBackpackObj()
        local current = bpObj and bpObj:GetAttribute("NewItems") or 0
        local step = tonumber(inputField.Text) or 1
        nextGoal = current + step
        
        statusLabel.Text = "Started! Target: " .. nextGoal
        castRod() 
    else
        statusLabel.Text = "Stopped"
    end
end)
