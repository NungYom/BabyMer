local function getRealNewItems()
    local bp = lp.Character:FindFirstChild("Backpack") or lp.Backpack:FindFirstChild("Backpack")
    return bp and bp:GetAttribute("NewItems") or 0
end

local function isTarget(itemName)
    local n = string.lower(tostring(itemName))
    for _, cat in ipairs(FilterSettings) do
        if cat.enabled then
            for _, t in ipairs(cat.items) do if string.find(n, string.lower(t)) then return true end end
        end
    end
    return false
end

local function pressSlot1()
    vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
    task.wait(0.05)
    vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
end

local function performCast()
    if not active then return end
    local char = lp.Character
    if not char then return end
    local rod = char:FindFirstChild("Rod") or lp.Backpack:FindFirstChild("Rod")
    if rod then
        if rod.Parent == lp.Backpack then pressSlot1() task.wait(0.3) end
        local attach = rod:FindFirstChild("Attachment", true)
        local root = char:FindFirstChild("HumanoidRootPart")
        if attach and root then
            ReplicatedStorage.Events.Global.Cast:FireServer(char.Humanoid, root.Position, root.CFrame.LookVector, attach)
        end
    end
end

-- ระบบ TheEye-Negative + Float (Check 1s)
task.spawn(function()
    while true do
        if theEyeActive and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local minute = os.date("!*t").min
            local root = lp.Character.HumanoidRootPart
            
            -- สร้างสถานะ Float (ล็อคตัวกลางอากาศ)
            local bodyVel = root:FindFirstChild("EyeFloat")
            if not bodyVel then
                bodyVel = Instance.new("BodyVelocity")
                bodyVel.Name = "EyeFloat"
                bodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
                bodyVel.Velocity = Vector3.new(0, 0, 0)
                bodyVel.Parent = root
            end

            -- TP ตามช่วงเวลา
            if (minute >= 0 and minute < 15) or (minute >= 30 and minute < 45) then
                root.CFrame = CFrame.lookAt(Vector3.new(206, 35, -302), Vector3.new(241.794388, 35, -312.383881))
            else
                root.CFrame = CFrame.lookAt(Vector3.new(370, 49, 137), Vector3.new(398.594147, 49, 144.852356))
            end
        else
            -- ลบสถานะ Float เมื่อปิดการใช้งาน
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local bodyVel = lp.Character.HumanoidRootPart:FindFirstChild("EyeFloat")
                if bodyVel then bodyVel:Destroy() end
            end
        end
        task.wait(1)
    end
end)

-- ระบบจัดการไอเทม
ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(success, p1, p2, items)
    if not (active and success and items) then return end
    task.spawn(function()
        local hasTarget = false
        for _, item in pairs(items) do if isTarget(item.name) then hasTarget = true break end end

        if hasTarget then
            local baseValue = getRealNewItems()
            local capacity = tonumber(lp.PlayerGui.ScreenGui.MainFrame.CapInput.Text) or 1
            local targetGoal = baseValue + capacity
            repeat
                for _, item in pairs(items) do if item.id then ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(item.id) end end
                task.wait(0.2)
            until getRealNewItems() >= targetGoal or not active
            if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(lp.Character.Humanoid)
            end
            task.wait(0.3)
        else
            pressSlot1() task.wait(0.2)
            pressSlot1() task.wait(0.3)
        end
        performCast()
    end)
end)

