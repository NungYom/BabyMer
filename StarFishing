for _, data in ipairs(FilterSettings) do
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1, -10, 0, 38); btn.Text = data.name .. ": ON"; btn.BackgroundColor3 = data.color; btn.TextColor3 = Color3.new(0,0,0)
    btn.MouseButton1Click:Connect(function()
        data.enabled = not data.enabled
        btn.Text = data.name .. (data.enabled and ": ON" or ": OFF")
        btn.BackgroundColor3 = data.enabled and data.color or Color3.fromRGB(60, 60, 60)
    end)
end

startBtn.MouseButton1Click:Connect(function()
    active = not active
    if active then
        -- กำหนดจุดหยุด: ค่าปัจจุบัน + จำนวนที่กรอก
        targetGoal = getBackpackValue() + (tonumber(capInput.Text) or 1)
        print("🎯 Goal Set to: " .. targetGoal)
        castRod()
    end
    startBtn.Text = active and "STOP" or "START HUNT"
    startBtn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)

modeBtn.MouseButton1Click:Connect(function()
    farmMode = (farmMode == "ALL") and "FILTER" or "ALL"
    modeBtn.Text = "MODE: " .. (farmMode == "ALL" and "ALL" or "FILTER")
end)
