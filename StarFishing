-- [[ FAST AUTO-FISH v32.4: MANUAL GEAR RESET MODE ]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local vim = game:GetService("VirtualInputManager")
local lp = Players.LocalPlayer

local active = false
local FilterSettings = {
    {name = "Common", color = Color3.fromRGB(160, 160, 160), enabled = false, items = {"Asteroid", "Gold Asteroid", "Comet"}},
    {name = "Uncommon", color = Color3.fromRGB(80, 220, 80), enabled = true, items = {"Hydrogen Star", "Orange Dwarf", "White Dwarf", "Helium", "Ice Comet"}},
    {name = "Rare", color = Color3.fromRGB(80, 160, 255), enabled = true, items = {"Blue Straggler", "Preon Star", "Ultraviolet", "Technetium Star"}},
    {name = "Epic", color = Color3.fromRGB(170, 80, 255), enabled = true, items = {"Collapsar", "X-Rey Binary Star", "Red Giant", "Blue Giant", "Unstable Star", "Quasar Core", "Luminous Blue Variable", "Antares", "Protoplanetary Disk", "Cosmic Dust", "Variable Carbon Star"}},
    {name = "Legendary", color = Color3.fromRGB(255, 140, 0), enabled = true, items = {"Luhman 16", "Young Binary Star", "Black Hole", "Molecular Cloud", "Blazer Core", "Blue Supergiant", "Red Supergiant"}},
    {name = "Mythic", color = Color3.fromRGB(255, 0, 100), enabled = true, items = {"The First Light", "Nebula", "Millisecond Pulsar", "Nova Persei 1901", "Przybylski's Star", "Dark Matter"}},
    {name = "Interstellar", color = Color3.fromRGB(0, 255, 255), enabled = true, items = {"1i Oumuamua", "2i Borisov", "3i ATLAS"}},
    {name = "Galactic", color = Color3.fromRGB(255, 100, 255), enabled = true, items = {"Supernova", "Prismatic Star", "Neutron Star"}},
    {name = "Other", color = Color3.fromRGB(255, 255, 255), enabled = true, items = {}}
}

local function getRealNewItems()
    local bp = lp.Character:FindFirstChild("Backpack") or lp.Backpack:FindFirstChild("Backpack")
    return bp and bp:GetAttribute("NewItems") or 0
end

local function isTarget(itemName)
    local n = string.lower(tostring(itemName))
    for _, cat in ipairs(FilterSettings) do
        if cat.enabled then
            for _, t in ipairs(cat.items) do
                if string.find(n, string.lower(t)) then return true end
            end
        end
    end
    return false
end

-- ฟังก์ชันจำลองการกดเลข 1 (Hotbar Slot 1)
local function pressSlot1()
    vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
    task.wait(0.05)
    vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
end

local function performCast()
    if not active then return end
    local char = lp.Character
    if not char then return end
    
    local rod = char:FindFirstChild("Rod") or lp.Backpack:FindFirstChild("Rod")
    if rod then
        -- ตรวจสอบว่าถือเบ็ดอยู่ไหม ถ้าไม่ให้กด 1
        if rod.Parent == lp.Backpack then
            pressSlot1()
            task.wait(0.3)
        end
        
        local attach = rod:FindFirstChild("Attachment", true)
        local root = char:FindFirstChild("HumanoidRootPart")
        if attach and root then
            ReplicatedStorage.Events.Global.Cast:FireServer(char.Humanoid, root.Position, root.CFrame.LookVector, attach)
            print("🚀 Cast!")
        end
    end
end

ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(success, p1, p2, items)
    if not (active and success and items) then return end
    
    task.spawn(function()
        local hasTarget = false
        for _, item in pairs(items) do
            if isTarget(item.name) then hasTarget = true break end
        end

        if hasTarget then
            -- [[ เจอของ: Collector Mode ]]
            local baseValue = getRealNewItems()
            local capacity = tonumber(lp.PlayerGui.ScreenGui.MainFrame.CapInput.Text) or 1
            local targetGoal = baseValue + capacity
            
            print("💎 Target! Collecting until NewItems is " .. targetGoal)
            
            local timeout = 0
            repeat
                for _, item in pairs(items) do
                    if item.id then ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(item.id) end
                end
                task.wait(0.2)
                timeout = timeout + 1
            until getRealNewItems() >= targetGoal or not active or timeout > 50
            
            -- หลังเก็บเสร็จ ให้ถอนเบ็ดออกปกติ
            if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(lp.Character.Humanoid)
            end
            task.wait(0.3)
        else
            -- [[ ไม่เจอของ: Hard Reset Mode ]]
            print("🚫 No target. Hard Resetting (Press 1 twice)...")
            
            -- กดปุ่ม 1 สองรอบ ห่างกัน 0.2 วิ ตามโจทย์
            pressSlot1() -- ครั้งที่ 1 (วางเบ็ด)
            task.wait(0.2)
            pressSlot1() -- ครั้งที่ 2 (ถือเบ็ดใหม่)
            task.wait(0.3) -- พักแป๊บนึงก่อนเหวี่ยง
        end

        -- เหวี่ยงเบ็ดรอบต่อไป
        performCast()
    end)
end)

