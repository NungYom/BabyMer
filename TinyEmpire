local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "🅇 BabeMer AutoFarm <3 (Smart Collect)",
   LoadingTitle = "กำลังเริ่มระบบดึงปุ่มเก็บของ...",
   LoadingSubtitle = "by Gemini AI",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("ฟาร์มหลัก", 4483362458)
local Player = game:GetService("Players").LocalPlayer

_G.AutoCollect = false

MainTab:CreateToggle({
   Name = "Auto Collect (ดึงปุ่มมาหาตัว)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
         task.spawn(function()
            while _G.AutoCollect do
               pcall(function()
                  local char = Player.Character
                  local root = char and char:FindFirstChild("HumanoidRootPart")
                  -- เข้าถึง Path: workspace.Plots.Plot3.Buildings
                  local buildings = workspace.Plots.Plot3.Buildings
                  
                  if root and buildings then
                     for _, building in pairs(buildings:GetChildren()) do
                        if not _G.AutoCollect then break end
                        
                        -- หา CollectPrompt (ซึ่งอยู่ใน Floor หรือส่วนอื่นๆ ของ Building)
                        local prompt = building:FindFirstChild("CollectPrompt", true)
                        local promptParent = prompt and prompt.Parent -- ปกติจะเป็น Floor
                        
                        -- เงื่อนไข: พร้อมกด และ มีของให้เก็บ (ObjectText ไม่ว่าง)
                        if prompt and prompt.Enabled and prompt.ObjectText ~= "" and promptParent:IsA("BasePart") then
                           local originalCFrame = promptParent.CFrame -- จำตำแหน่งเดิม
                           
                           -- 1. ดึง Part มาที่ตัวผู้เล่น
                           promptParent.CFrame = root.CFrame
                           task.wait(0.1) -- รอให้ Engine รับรู้ว่าปุ่มอยู่ใกล้เราแล้ว
                           
                           -- 2. สั่งกด E (Fire Prompt)
                           fireproximityprompt(prompt)
                           
                           -- 3. ส่ง Part กลับที่เดิมทันที
                           promptParent.CFrame = originalCFrame
                           task.wait(0.1)
                        end
                     end
                  end
               end)
               task.wait(2) -- พัก 2 วินาทีก่อนเริ่มวนลูปใหม่
            end
         end)
      end
   end,
})
