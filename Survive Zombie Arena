local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidShard & Spin Bot",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by Professional Collaborator",
   KeySystem = false,
})

local Tab = Window:CreateTab("Main", nil)

-- ตัวแปรสถานะ
local AutoFarmEnabled = false
local AutoSpinEnabled = false
local StartPosition = nil

-- Toggle สำหรับ Teleport (เก็บของ)
Tab:CreateToggle({
   Name = "Auto Farm VoidShards",
   CurrentValue = false,
   Flag = "AutoFarmToggle",
   Callback = function(Value)
      AutoFarmEnabled = Value
      if AutoFarmEnabled then
         StartPosition = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
         task.spawn(function()
            while AutoFarmEnabled do
               local workspace = game:GetService("Workspace")
               local parts = {}
               for _, obj in pairs(workspace:GetDescendants()) do
                  if obj:IsA("BasePart") and obj.Name == "VoidShardPart" then
                     table.insert(parts, obj)
                  end
               end
               
               for _, part in pairs(parts) do
                  if not AutoFarmEnabled then break end
                  game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = part.CFrame
                  task.wait(0.1)
               end
               
               if AutoFarmEnabled and StartPosition then
                  game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = StartPosition
                  task.wait(10)
               end
            end
         end)
      else
         StartPosition = nil
      end
   end,
})

-- Toggle สำหรับ Auto Spin
Tab:CreateToggle({
   Name = "Auto Spin GalacticRequest",
   CurrentValue = false,
   Flag = "AutoSpinToggle",
   Callback = function(Value)
      AutoSpinEnabled = Value
      if AutoSpinEnabled then
         task.spawn(function()
            while AutoSpinEnabled do
               local success, err = pcall(function()
                  game:GetService("ReplicatedStorage"):WaitForChild("EventRemotes"):WaitForChild("GalacticRequestSpin"):InvokeServer()
               end)
               
               if not success then
                  warn("Spin Error: " .. tostring(err))
               end
               
               task.wait(0.1)
            end
         end)
      end
   end,
})
