local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Plot Farming Hub",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by Gemini",
})

-- จัดระเบียบหน้า Tab
local FarmTab = Window:CreateTab("Auto Farm")
local ShopTab = Window:CreateTab("Auto Shop")

-- ตัวแปรเก็บสถานะการซื้อ
local buySettings = {
    Capsule = {KingMolarCapsule = false, NebuliteCapsule = false, GlitchfangCapsule = false},
    Tooth = {Twinkle = false, Ladybug = false, Fruitopia = false, Voidcore = false, Celestialino = false},
    PlotSkin = {WingPlotSkin = false, GrasshopperPlotSkin = false, PinkPlotSkin = false, RainbowPlotSkin = false, GalaxyPlotSkin = false}
}

-- ฟังก์ชันดึง Plot
local function getMyPlot()
    local player = game.Players.LocalPlayer
    local plotsFolder = game.Workspace:FindFirstChild("Plots")
    if plotsFolder then
        for i = 1, 6 do
            local plot = plotsFolder:FindFirstChild("Plot" .. i)
            if plot and plot:GetAttribute("OwnerUserId") == player.UserId then
                return plot
            end
        end
    end
    return nil
end

-- 1. Auto Collect (ปรับ Logic: ดึงมา 1 วิ แล้วส่งคืน รอ 3 วิแล้วค่อยทำใหม่)
local autoCollect = false
FarmTab:CreateToggle({
   Name = "Auto Collect Money",
   Callback = function(Value)
      autoCollect = Value
      if autoCollect then
         spawn(function()
            while autoCollect do
               local myPlot = getMyPlot()
               if myPlot then
                  local lowerPlots = myPlot:FindFirstChild("LowerPlots")
                  if lowerPlots then
                     local collectedParts = {}
                     -- ดึงมา
                     for j = 1, 30 do
                        local p = lowerPlots:FindFirstChild("LowerPlots." .. string.format("%03d", j))
                        local part = p and p:FindFirstChild("CalciumCollect") and p.CalciumCollect:FindFirstChild("Part")
                        if part then
                           table.insert(collectedParts, {obj = part, pos = part.CFrame})
                           part.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
                        end
                     end
                     task.wait(1) -- ค้างไว้ 1 วิ
                     -- ส่งคืน
                     for _, data in pairs(collectedParts) do
                        data.obj.CFrame = data.pos
                     end
                  end
               end
               task.wait(3) -- รอ 3 วิ
            end
         end)
      end
   end,
})

-- 2. Auto Level Up (เหมือนเดิม)
local autoLevel = false
FarmTab:CreateToggle({Name = "Auto Level Up", Callback = function(V) autoLevel = V end})
spawn(function()
    while true do
        if autoLevel then
            local myPlot = getMyPlot()
            if myPlot then
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes") and game:GetService("ReplicatedStorage").Remotes:FindFirstChild("LevelUpTooth")
                for j = 1, 30 do
                    if not autoLevel then break end
                    remote:FireServer(string.format("LowerPlots.%03d", j))
                    task.wait(0.1)
                end
            end
        end
        task.wait(0.1)
    end
end)

-- 3. Auto Rebirth
local autoRebirth = false
FarmTab:CreateToggle({Name = "Auto Rebirth", Callback = function(V) autoRebirth = V end})
spawn(function()
    while true do
        if autoRebirth then
            local r = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes") and game:GetService("ReplicatedStorage").Remotes:FindFirstChild("RequestRebirth")
            if r then r:FireServer() end
        end
        task.wait(1)
    end
end)

-- 4. Auto Buy (ใน ShopTab)
for category, items in pairs(buySettings) do
    ShopTab:CreateSection(category)
    for itemName, _ in pairs(items) do
        ShopTab:CreateToggle({
            Name = "Buy " .. itemName,
            Callback = function(V) buySettings[category][itemName] = V end
        })
    end
end

-- ระบบลูปซื้อแยกตามประเภท
spawn(function()
    while true do
        for cat, items in pairs(buySettings) do
            for name, enabled in pairs(items) do
                if enabled then
                    local remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
                    if cat == "Capsule" then
                        remotes:WaitForChild("BuyCapsule"):FireServer(name, false)
                    else
                        remotes:WaitForChild("FairyShopBuyItem"):FireServer(name)
                    end
                end
            end
        end
        task.wait(1)
    end
end)
