-- แจ้งสถานะใน Console
print("------------------------------------------")
print("Gemini Pro: Distance-Based Auto Attack")
print("Status: Running...")
print("------------------------------------------")

local Player = game:GetService("Players").LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local Remote = RS:WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")

-- ระยะที่จะให้สคริปต์เริ่มทำงาน (ปรับเลข 20 เพิ่ม/ลดได้)
local AttackDistance = 20 

-- ฟังก์ชันหาตัวมอนสเตอร์ที่ใกล้ที่สุด
local function getNearestMonster()
    local target = nil
    local dist = AttackDistance
    
    -- สมมติว่ามอนสเตอร์อยู่ใน Workspace (ต้องเช็คชื่อ Folder มอนสเตอร์ในเกมอีกที)
    for _, v in pairs(game.Workspace:GetChildren()) do
        -- เช็คว่าเป็นตัวที่มีเลือด (มักจะมี Humanoid) และไม่ใช่ตัวเรา
        if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v ~= Player.Character then
            local magnitude = (Player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).magnitude
            if magnitude < dist then
                dist = magnitude
                target = v
            end
        end
    end
    return target
end

-- ลูปการทำงาน
task.spawn(function()
    while true do
        local target = getNearestMonster()
        
        if target then
            -- สร้าง Args โดยใช้ ID ของมอนสเตอร์ที่เจอ
            -- หมายเหตุ: ID ต้องดึงจาก Attributes หรือชื่อ ตามที่เกมกำหนด
            -- ตรงนี้ผมใช้รูปแบบ Remote ที่นายให้มาตอนแรก
            local monsterID = target:GetAttribute("ID") or target.Name -- ปรับตามความเหมาะสมของเกม
            
            local args = {
                {
                    {
                        "General",
                        "Attack",
                        "Click",
                        {
                            [tostring(monsterID)] = true
                        },
                        n = 4
                    },
                    "\002"
                }
            }
            
            pcall(function()
                Remote:FireServer(unpack(args))
            end)
        end
        
        task.wait(0.1) -- ความเร็วในการสแกนและตี (0.1 = 10 ครั้งต่อวิ)
    end
end)
