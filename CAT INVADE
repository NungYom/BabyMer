local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local Window = Rayfield:CreateWindow({Name = "Auto Farm Fixed", LoadingTitle = "Loading...", LoadingSubtitle = "Fixed version"})
local Tab = Window:CreateTab("Combat", nil)

getgenv().AutoFire = false
Tab:CreateToggle({
   Name = "Auto Fire (Fixed)",
   CurrentValue = false,
   Callback = function(Value) getgenv().AutoFire = Value end,
})

-- ฟังก์ชันหาตำแหน่งที่แม่นยำขึ้น
local function getNearestTarget()
    local closestPos = nil
    local shortestDist = math.huge
    
    -- อ้างอิงตามที่คุณบอกว่าชื่อผู้เล่นคือชื่อตัวละครใน Workspace
    local playerChar = Workspace:FindFirstChild(Players.LocalPlayer.Name)
    local playerRoot = playerChar and playerChar:FindFirstChild("HumanoidRootPart")
    if not playerRoot then return nil end

    -- โฟลเดอร์มอนสเตอร์ตามโครงสร้างใน image_e5aba1.png
    local container = Workspace._Map.Cats.Container
    
    for _, obj in pairs(container:GetChildren()) do
        -- เช็คหาพิกัดตำแหน่งจากวัตถุ (ใช้วิธีหาตำแหน่งจาก Part ที่อยู่ข้างในหรือตัวมันเอง)
        local targetPos = (obj:IsA("Model") and (obj.PrimaryPart and obj.PrimaryPart.Position or obj:FindFirstChildWhichIsA("BasePart").Position)) 
                       or (obj:IsA("BasePart") and obj.Position)
        
        if targetPos then
            local dist = (targetPos - playerRoot.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestPos = targetPos
            end
        end
    end
    return closestPos, playerRoot.Position
end

task.spawn(function()
    while task.wait(0.2) do -- ปรับเพิ่มเวลาเผื่อ Server รับค่าไม่ทัน
        if getgenv().AutoFire then
            local targetPos, playerPos = getNearestTarget()
            
            if targetPos and playerPos then
                -- คำนวณ Direction Vector ให้พุ่งไปที่เป้าหมาย
                local direction = (targetPos - playerPos).Unit
                
                local args = {
                    Vector3.new(direction.X, direction.Y, direction.Z),
                    true
                }
                
                game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("WeaponEvent"):FireServer(unpack(args))
            end
        end
    end
end)
