--==================================================
-- MAIN LOOPS
--==================================================

task.spawn(function()
    while true do
        if autoAttack then
            -- เช็คว่าเป้าหมายเดิมตาย/หายไปหรือยัง
            if not currentTarget or not currentTarget.Parent or not currentTarget:FindFirstChild("Model") then
                currentTarget = findNewTarget()
            end

            if currentTarget then
                local root = currentTarget.Model:FindFirstChild("Root")
                local weapon = getWeapon()
                
                if root and weapon then
                    FireRE:FireServer("Hit", {
                        fishInstance = currentTarget,
                        HitPos = root.Position,
                        toolInstance = weapon
                    })
                end
                
                -- เอาเรื่องสกิลมารันต่อเมื่อมีเป้าหมายเท่านั้น
                if autoSkill then task.spawn(castSkill) end
            else
                -- **กันเหนียว:** เผื่อหาปลาไม่เจอ แต่เปิดออโต้สกิลไว้ ก็ให้ใช้สกิลไปพรางๆ
                if autoSkill then task.spawn(castSkill) end
            end
        end
        task.wait(0.2)
    end
end)
