local function getWeapon()
    for _,v in ipairs(character:GetChildren()) do
        if v:IsA("Tool") and (v.Name:match("^Gun%d+$") or v.Name:match("^Harpoon%d+$")) then return v end
    end
    for _,v in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") and (v.Name:match("^Gun%d+$") or v.Name:match("^Harpoon%d+$")) then return v end
    end
end

-- ฟังก์ชันหาเป้าหมายที่แก้ไขตามโครงสร้างจริง
local function findNewTarget()
    local nearest, dist = nil, math.huge
    
    -- 1. หาใน WorldSea (WorldSea -> SeaX -> FishX -> Model -> Root)
    local seaFolder = workspace:FindFirstChild("WorldSea")
    if seaFolder then
        for _, sea in ipairs(seaFolder:GetChildren()) do
            for _, fish in ipairs(sea:GetChildren()) do
                local model = fish:FindFirstChild("Model")
                if model then
                    local root = model:FindFirstChild("Root")
                    if root and root:IsA("BasePart") then
                        local d = (HRP.Position - root.Position).Magnitude
                        if d < dist then
                            dist = d
                            nearest = fish -- เก็บตัว Fish (เช่น Fish501)
                        end
                    end
                end
            end
        end
    end

    -- 2. หาใน WorldBoss (WorldBoss -> PointX -> BossX -> Model -> Root)
    local bossFolder = workspace:FindFirstChild("WorldBoss")
    if bossFolder then
        for _, point in ipairs(bossFolder:GetChildren()) do
            for _, boss in ipairs(point:GetChildren()) do
                local model = boss:FindFirstChild("Model")
                if model then
                    local root = model:FindFirstChild("Root")
                    if root and root:IsA("BasePart") then
                        local d = (HRP.Position - root.Position).Magnitude
                        if d < dist then
                            dist = d
                            nearest = boss -- เก็บตัว Boss (เช่น Boss03)
                        end
                    end
                end
            end
        end
    end

    return nearest
end

-- ระบบสกิล 01-14 (Delay 0.15)
local function castSkill()
    if skillBusy then return end
    skillBusy = true
    for i=1, 14 do
        if not autoSkill then break end
        FishRE:FireServer("Skill", {ID = string.format("Skill%02d", i)})
        task.wait(0.15) 
    end
    skillBusy = false
end

